---
// 招牌互動：位置定址 vs 內容定址。封網域/砍伺服器後 HTTP 失效，IPFS 仍可讀。
---
<div class="ad" id="ad-root">
  <div class="ad-cols">
    <div class="ad-col">
      <h4>位置定址（HTTP）</h4>
      <div class="ad-box ad-server" id="ad-server">
        <div class="ad-domain">matters.town</div>
        <div class="ad-doc">📄 一篇文章</div>
      </div>
      <p class="ad-status ad-ok" id="ad-http">✓ 讀得到</p>
    </div>
    <div class="ad-col">
      <h4>內容定址（IPFS · 內容指紋 CID）</h4>
      <div class="ad-nodes" id="ad-nodes">
        <div class="ad-node">📄</div>
        <div class="ad-node">📄</div>
        <div class="ad-node">📄</div>
        <div class="ad-node">📄</div>
      </div>
      <p class="ad-status ad-ok" id="ad-ipfs">✓ 讀得到（4 個節點持有同一 CID）</p>
    </div>
  </div>
  <div class="ad-controls">
    <button type="button" id="ad-block">🚫 封鎖網域／砍掉中心伺服器</button>
    <button type="button" id="ad-kill">砍掉一個 IPFS 節點</button>
    <button type="button" id="ad-reset" class="ad-reset">重置</button>
  </div>
  <p class="ad-out" id="ad-out" aria-live="polite">按「封鎖網域」，比較兩種定址方式的命運。</p>
  <noscript><p class="ad-out">互動需 JavaScript。重點：HTTP 把內容綁在網域/伺服器上，刪檔或改 DNS 就失效；IPFS 用內容指紋（CID）定址，只要還有一個節點持有就讀得到——這就是 2025 春節 matters.town 網域被 DNS-RPZ 封鎖時，文章仍能經 IPFS 取得的原因。</p></noscript>
</div>

<style>
  .ad { max-width: 640px; margin: 0 auto; }
  .ad-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .ad-col h4 { font-family: var(--font-ui); font-size: 14px; margin: 0 0 8px; text-align: center; }
  .ad-box, .ad-node { transition: opacity .4s, filter .4s; }
  .ad-server { background: var(--bg-paper); border: 1px solid var(--line); border-radius: 12px; padding: 16px; text-align: center; }
  .ad-domain { font-family: var(--font-ui); font-size: 13px; color: var(--ink-soft); }
  .ad-doc { font-size: 20px; margin-top: 8px; }
  .ad-nodes { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .ad-node { background: var(--bg-paper); border: 1px solid var(--line); border-radius: 10px; padding: 12px; text-align: center; font-size: 20px; }
  .ad-dead { opacity: .3; filter: grayscale(1); }
  .ad-status { text-align: center; font-family: var(--font-ui); font-size: 13px; margin-top: 8px; }
  .ad-ok { color: var(--c-legit, #6f8f4e); }
  .ad-bad { color: var(--c-spam, #c0584a); }
  .ad-controls { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin: 16px 0 10px; }
  .ad-controls button { font: 700 14px var(--font-ui); padding: 8px 14px; border-radius: 999px;
    border: 1.5px solid var(--accent, #7258FF); background: #fff; color: var(--accent, #7258FF); cursor: pointer; }
  .ad-controls button:hover { background: var(--accent, #7258FF); color: #fff; }
  .ad-controls .ad-reset { border-color: var(--line); color: var(--ink-soft); }
  .ad-out { text-align: center; font-size: 16px; min-height: 3em; max-width: 560px; margin: 0 auto; }
  @media (prefers-reduced-motion: reduce) { .ad-box, .ad-node { transition: none; } }
</style>

<script is:inline>
  (function () {
    var root = document.getElementById('ad-root');
    if (!root) return;
    var server = document.getElementById('ad-server');
    var http = document.getElementById('ad-http');
    var ipfs = document.getElementById('ad-ipfs');
    var nodes = [].slice.call(root.querySelectorAll('.ad-node'));
    var out = document.getElementById('ad-out');
    function alive() { return nodes.filter(function (n) { return !n.classList.contains('ad-dead'); }).length; }
    function refreshIpfs() {
      var a = alive();
      if (a > 0) { ipfs.className = 'ad-status ad-ok'; ipfs.textContent = '✓ 讀得到（' + a + ' 個節點持有同一 CID）'; }
      else { ipfs.className = 'ad-status ad-bad'; ipfs.textContent = '✗ 內容消失（所有節點都沒了）'; }
    }
    document.getElementById('ad-block').onclick = function () {
      server.classList.add('ad-dead');
      http.className = 'ad-status ad-bad'; http.textContent = '✗ 404 連不上（檔案被刪／網域被封）';
      out.innerHTML = '<strong>位置定址</strong>：刪檔或改寫 DNS，內容就失效。<strong>內容定址</strong>：CID 還在節點上，照樣讀得到——這正是 2025 春節網域被 DNS-RPZ 封鎖時，文章仍能經 IPFS 取得的原因。';
    };
    document.getElementById('ad-kill').onclick = function () {
      var live = nodes.filter(function (n) { return !n.classList.contains('ad-dead'); });
      if (live.length) live[0].classList.add('ad-dead');
      refreshIpfs();
      if (alive() > 0) out.innerHTML = '砍掉一個節點，只要還有<strong>任何一個</strong>節點持有 CID，內容就還在。要讓它真正消失，得砍光<strong>所有</strong>節點。';
      else out.innerHTML = '砍光所有節點，內容才真的消失——但在真實世界，IPFS 內容散在全球許多節點上，這幾乎做不到。';
    };
    document.getElementById('ad-reset').onclick = function () {
      server.classList.remove('ad-dead');
      http.className = 'ad-status ad-ok'; http.textContent = '✓ 讀得到';
      nodes.forEach(function (n) { n.classList.remove('ad-dead'); });
      refreshIpfs();
      out.textContent = '按「封鎖網域」，比較兩種定址方式的命運。';
    };
  })();
</script>
