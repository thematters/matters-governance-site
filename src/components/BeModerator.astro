---
// 招牌互動：be-the-moderator。逐則判「擋/放」，揭曉模型分數與後果，最後算總帳。
const cards = [
  { truth: 'spam',  cat: '色情廣告',     score: 99, text: 'Call Girls／外送茶 全套 在地約妹 加賴 ‹LINE_ID›', why: '明確的色情招攬，模型高分、人眼也一眼看穿。' },
  { truth: 'legit', cat: '日記',         score: 3,  text: '日記·超級生命密碼', why: '私人日記，無導流、無招攬，模型低分。' },
  { truth: 'legit', cat: '防詐科普',     score: 85, text: '拆解 USDT「穩賺套利」詐騙話術（引述常見錢包與賴 ID 騙術）', why: '為了教學而引述詐騙話術，分數被拉高——但它正是在反詐騙。擋了，就誤殺了防詐內容。' },
  { truth: 'spam',  cat: '翻譯社（集團）', score: 9,  text: '高雄翻譯社 證件公證 各國文件 急件當日 ‹LINE_ID›', why: '單篇分數只有 0.09、看起來正常，卻是 14 個帳號用同一模板洗版的集團——低分不代表安全。' },
  { truth: 'legit', cat: '人權議題',     score: 96, text: '海外中國人權律師聯盟之處境與聲援', why: '敏感詞密集讓模型給到 0.96，但這是合法的人權議題寫作。擋了，就消音了一個最該被保護的聲音。' },
  { truth: 'spam',  cat: '二次詐騙',     score: 85, text: '我曾被詐騙 30 萬，後來找團隊幫我追回，你也遇到詐騙就私訊我', why: '偽裝成受害者經驗，實則進行第二輪詐騙——正是觸發 2025 年 DNS-RPZ 封鎖的那類文。' },
];
---
<div class="bm" id="bm-root">
  <script type="application/json" id="bm-data" set:html={JSON.stringify(cards)}></script>
  <div class="bm-stage" id="bm-stage"></div>
  <div class="bm-tally" id="bm-tally" hidden>
    <span>正確 <b id="bm-ok">0</b></span>
    <span class="bm-fp">誤殺 <b id="bm-fp">0</b></span>
    <span class="bm-fn">漏放 <b id="bm-fn">0</b></span>
  </div>
  <noscript><p class="bm-note">這是一個「換你當審查員」的小測驗：逐則判斷「擋下/放行」，再揭曉模型分數與後果。請開啟 JavaScript。重點：明確的色情/賭博廣告好判，但防詐科普、人權議題、集團洗版這些灰區，才是審查最難、最容易誤殺或漏放的地方。</p></noscript>
</div>

<style>
  .bm { max-width: 600px; margin: 0 auto; }
  .bm-stage { background: var(--bg-paper); border: 1px solid var(--line); border-radius: 14px; padding: 20px; }
  .bm-cat { font-family: var(--font-ui); font-size: 12px; font-weight: 700; color: var(--ink-soft); }
  .bm-text { font-size: 19px; margin: 8px 0 16px; line-height: 1.6; }
  .bm-progress { font-family: var(--font-ui); font-size: 12px; color: var(--ink-soft); float: right; }
  .bm-btns { display: flex; gap: 12px; }
  .bm-btns button { flex: 1; font: 700 16px var(--font-ui); padding: 12px; border-radius: 10px; cursor: pointer; border: 1.5px solid; }
  .bm-block { border-color: var(--c-spam, #c0584a); color: var(--c-spam, #c0584a); background: #fff; }
  .bm-block:hover { background: var(--c-spam, #c0584a); color: #fff; }
  .bm-allow { border-color: var(--c-legit, #6f8f4e); color: var(--c-legit, #6f8f4e); background: #fff; }
  .bm-allow:hover { background: var(--c-legit, #6f8f4e); color: #fff; }
  .bm-reveal { margin-top: 14px; }
  .bm-score { font-family: var(--font-ui); font-size: 14px; }
  .bm-verdict { font-weight: 800; font-size: 17px; margin: 6px 0; }
  .bm-ok-v { color: var(--c-legit, #6f8f4e); }
  .bm-bad-v { color: var(--c-spam, #c0584a); }
  .bm-why { font-size: 15px; color: var(--ink-soft); }
  .bm-next { margin-top: 14px; font: 700 15px var(--font-ui); padding: 9px 18px; border-radius: 999px;
    border: 0; background: var(--accent, #7258FF); color: #fff; cursor: pointer; }
  .bm-tally { display: flex; gap: 18px; justify-content: center; margin-top: 14px; font-family: var(--font-ui); font-size: 14px; }
  .bm-tally .bm-fp b { color: var(--c-spam, #c0584a); }
  .bm-tally .bm-fn b { color: #b8860b; }
  .bm-summary { text-align: center; }
  .bm-summary h3 { font-size: 22px; margin: 4px 0; }
</style>

<script is:inline>
  (function () {
    var root = document.getElementById('bm-root');
    if (!root) return;
    var cards = JSON.parse(document.getElementById('bm-data').textContent);
    var stage = document.getElementById('bm-stage');
    var tallyEl = document.getElementById('bm-tally');
    var i = 0, ok = 0, fp = 0, fn = 0;
    function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function show() {
      var c = cards[i];
      stage.innerHTML =
        '<span class="bm-progress">' + (i + 1) + ' / ' + cards.length + '</span>' +
        '<span class="bm-cat">' + esc(c.cat) + '</span>' +
        '<p class="bm-text">「' + esc(c.text) + '」</p>' +
        '<div class="bm-btns"><button class="bm-block" id="bm-b">擋下（是垃圾）</button>' +
        '<button class="bm-allow" id="bm-a">放行（是正常）</button></div>';
      document.getElementById('bm-b').onclick = function () { answer('block'); };
      document.getElementById('bm-a').onclick = function () { answer('allow'); };
    }
    function answer(act) {
      var c = cards[i];
      var spam = c.truth === 'spam';
      var verdict, cls;
      if (act === 'block' && spam) { verdict = '✓ 擋對了'; cls = 'bm-ok-v'; ok++; }
      else if (act === 'block' && !spam) { verdict = '✗ 誤殺！這是正常內容（偽陽性）'; cls = 'bm-bad-v'; fp++; }
      else if (act === 'allow' && spam) { verdict = '✗ 漏放！這是垃圾（偽陰性）'; cls = 'bm-bad-v'; fn++; }
      else { verdict = '✓ 放對了'; cls = 'bm-ok-v'; ok++; }
      tallyEl.hidden = false;
      document.getElementById('bm-ok').textContent = ok;
      document.getElementById('bm-fp').textContent = fp;
      document.getElementById('bm-fn').textContent = fn;
      stage.innerHTML =
        '<span class="bm-cat">' + esc(c.cat) + '</span>' +
        '<p class="bm-text">「' + esc(c.text) + '」</p>' +
        '<div class="bm-reveal"><p class="bm-score">模型分數：<b>' + (c.score / 100).toFixed(2) + '</b>　真相：' + (spam ? '垃圾' : '正常') + '</p>' +
        '<p class="bm-verdict ' + cls + '">' + verdict + '</p>' +
        '<p class="bm-why">' + esc(c.why) + '</p>' +
        '<button class="bm-next" id="bm-n">' + (i < cards.length - 1 ? '下一則 →' : '看結果') + '</button></div>';
      document.getElementById('bm-n').onclick = function () { i++; (i < cards.length) ? show() : end(); };
    }
    function end() {
      stage.innerHTML =
        '<div class="bm-summary"><h3>當審查員，比想像中難</h3>' +
        '<p>你誤殺了 <b style="color:var(--c-spam,#c0584a)">' + fp + '</b> 篇正常內容、漏放了 <b style="color:#b8860b">' + fn + '</b> 篇垃圾。</p>' +
        '<p class="bm-why">明確的色情、賭博廣告好判；但防詐科普、人權議題、集團洗版這些灰區，才是審查最難、最容易誤殺或漏放的地方。每一個門檻，都是別人言論的生死線——這不該由工程師獨自決定。</p>' +
        '<button class="bm-next" id="bm-r">再玩一次</button></div>';
      document.getElementById('bm-r').onclick = function () { i = 0; ok = 0; fp = 0; fn = 0; tallyEl.hidden = true; show(); };
    }
    show();
  })();
</script>
