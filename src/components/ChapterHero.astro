---
// 分頁統一章節 hero：滿版底圖（或影片迴圈）+ scrim + 疊字。
interface Props {
  kicker: string;
  title: string;
  img: string;          // 相對路徑，如 illustrations/detection.jpg（也當影片 poster）
  alt: string;
  video?: string;       // anim/ 下檔名（不含副檔名），如 detection-robot-high-motion-4s
}
const { kicker, title, img, alt, video } = Astro.props;
---
<section class="full-bleed banner banner--chapter">
  {video ? (
    <video class="banner-media" muted loop playsinline preload="none" poster={img} aria-hidden="true" data-autoplay>
      <source src={`illustrations/anim/${video}.webm`} type="video/webm" />
      <source src={`illustrations/anim/${video}.mp4`} type="video/mp4" />
    </video>
  ) : (
    <img src={img} alt={alt} />
  )}
  <div class="banner__inner">
    <p class="kicker">{kicker}</p>
    <h1 set:html={title} />
  </div>
</section>
