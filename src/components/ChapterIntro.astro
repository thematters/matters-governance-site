---
// 首頁章節開場標題段：透明區段，背景由全域固定 #stage（各章靜態圖交叉淡入）提供。
// 章節圖是「持續的章節背景」（變暗以利閱讀），內容直接疊在上面——故此段只承載白色大標，
// 不自帶底圖/影片/sticky；data-stage 讓 #stage 知道捲到本章時要淡入哪張圖。
interface Props {
  id: string;     // rail 錨點，如 ch-1
  num: string;    // 第一章
  name: string;   // 魔高一尺
  desc: string;   // 一句說明
  stage: number;  // 對應 #stage 第幾張底圖
}
const { id, num, name, desc, stage } = Astro.props;
---
<section class="chintro" id={id} data-stage={stage}>
  <div class="chintro__title">
    <p class="chintro__num">{num}</p>
    <h2 class="chintro__name">{name}</h2>
    <p class="chintro__desc">{desc}</p>
  </div>
</section>

<style>
  /* 透明章節開場：一屏高、白色大標置中，背景＝全域 #stage 的章節圖（已變暗） */
  .chintro { position: relative; min-height: 88vh; display: flex; align-items: center; justify-content: center;
    text-align: center; padding: 14vh 20px; }
  .chintro__title { max-width: 780px; color: #fff; }
  .chintro__num { font: 800 13px/1 var(--font-ui); letter-spacing: .34em; margin: 0 0 16px;
    color: rgba(255,255,255,.9); }
  .chintro__num::before, .chintro__num::after { content: ''; display: inline-block;
    width: 28px; height: 1.5px; vertical-align: middle; margin: 0 13px 4px; background: rgba(255,255,255,.6); }
  .chintro__name { font: 800 clamp(36px, 7.4vw, 64px)/1.1 var(--font-read); margin: 0 0 16px;
    color: #fff; letter-spacing: .03em; text-shadow: 0 2px 28px rgba(0,0,0,.6), 0 1px 5px rgba(0,0,0,.5); }
  .chintro__desc { font: 500 clamp(15px, 2.4vw, 19px)/1.75 var(--font-ui); margin: 0 auto; max-width: 28em;
    color: rgba(255,255,255,.88); text-shadow: 0 1px 14px rgba(0,0,0,.6); }
  @media (max-width: 680px) { .chintro { min-height: 78vh; } }
</style>
