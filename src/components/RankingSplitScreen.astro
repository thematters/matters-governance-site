---
// 招牌互動：排序 split-screen + Place Your Bets。
// 上半：一條 feed，先猜哪則會被演算法排到首頁第一名（卡片＝Matters ArticleCard）。
// 下半（揭曉）：兩欄並列同一批內容——左「時間序」vs 右「演算法序」，
//   兩欄都是真 feed 貼文卡，標出名次①②③④⑤＋兩欄間的位移（↑/↓），一眼看出「誰被推上去、誰被壓下來」。
// 演算法分數 = 0.3·讀 + 0.4·留言 + 0.3·賞（各訊號正規化）。留言權重最高 → 引發討論勝過高曝光。
const posts = [
  { id: 'A', title: '爆紅迷因整理：這週讓全網笑翻的 12 張圖', author: '迷因日報',   time: '3 分鐘前',  hue: 38,  reads: 5000, comments: 2,  donations: 1 },
  { id: 'B', title: '能源政策的公共討論：核三延役該不該',       author: '政策觀察室', time: '1 小時前',  hue: 168, reads: 800,  comments: 60, donations: 5 },
  { id: 'C', title: '獨立記者的群眾募資：我們想做的調查報導',     author: '林記者',     time: '2 小時前',  hue: 262, reads: 600,  comments: 10, donations: 40 },
  { id: 'D', title: '午後日常隨筆：關於一杯咖啡的小事',           author: '日常',       time: '25 分鐘前', hue: 96,  reads: 300,  comments: 8,  donations: 3 },
  { id: 'E', title: '剛發佈的時事分析：今天那場記者會的三個重點', author: '時事快評',   time: '剛剛',     hue: 4,   reads: 2000, comments: 20, donations: 8 },
];
const maxR = Math.max(...posts.map((p) => p.reads));
const maxC = Math.max(...posts.map((p) => p.comments));
const maxD = Math.max(...posts.map((p) => p.donations));
const scored = posts.map((p) => ({
  ...p,
  score: 0.3 * (p.reads / maxR) + 0.4 * (p.comments / maxC) + 0.3 * (p.donations / maxD),
}));
const byAlgo = [...scored].sort((a, b) => b.score - a.score);
const byTime = ['E', 'B', 'C', 'A', 'D'].map((id) => scored.find((p) => p.id === id));
const algoTop = byAlgo[0].id;

// 時間序名次（給每則一個 data 屬性，揭曉時算位移用）
const timeRank = {};
byTime.forEach((p, i) => { timeRank[p.id] = i + 1; });
const rankGlyph = ['①', '②', '③', '④', '⑤'];
---
<div class="rk" id="rk-root" data-top={algoTop}>
  <p class="rk-q" id="rk-q">先猜：這條 feed 裡，哪一則會被演算法排到<strong>首頁第一名</strong>？點一則。</p>

  <div class="rk-cards" role="list">
    {scored.map((p) => (
      <button type="button" class="rk-card" data-id={p.id} role="listitem">
        <span class="fi-avatar" style={`background:hsl(${p.hue} 55% 55%)`}>{p.author.slice(0, 1)}</span>
        <span class="fi-body">
          <span class="fi-head"><span class="fi-author">{p.author}</span><span class="fi-time">· {p.time}</span></span>
          <span class="rk-title fi-title">{p.title}</span>
          <span class="fi-meta">
            <span class="fi-stat"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>{p.reads.toLocaleString()}</span>
            <span class="fi-stat"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 11.5A8.5 8.5 0 0 1 12.5 20a8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.5 8.5 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3 8.5 8.5 0 0 1 21 11.5z"/></svg>{p.comments}</span>
            <span class="fi-stat"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M9.5 9.5h4a2 2 0 0 1 0 4h-3.5"/></svg>{p.donations}</span>
          </span>
        </span>
      </button>
    ))}
  </div>

  <div class="rk-reveal" id="rk-reveal" hidden>
    <p class="rk-swipehint" aria-hidden="true">← 左右滑，比較<span>時間序 ↔ 演算法序</span> →</p>
    <div class="rk-cols">
      <section class="rk-col rk-col-time" aria-label="時間序的首頁">
        <header class="rk-colhead">
          <span class="rk-colicon" aria-hidden="true">🕒</span>
          <span class="rk-coltitle">時間序</span>
          <span class="rk-colsub">剛發布在最上</span>
        </header>
        <ol class="rk-feed" role="list">
          {byTime.map((p, i) => (
            <li class="rk-fcard" data-id={p.id} role="listitem">
              <span class="rk-rank" aria-hidden="true">{rankGlyph[i]}</span>
              <span class="rk-fcard__body">
                <span class="rk-fhead">
                  <span class="rk-favatar" style={`background:hsl(${p.hue} 55% 55%)`} aria-hidden="true">{p.author.slice(0, 1)}</span>
                  <span class="rk-fauthor">{p.author}</span>
                  <span class="rk-ftime">· {p.time}</span>
                </span>
                <span class="rk-ftitle">{p.title}</span>
                <span class="rk-fmeta">
                  <span class="rk-fstat"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>{p.reads.toLocaleString()}</span>
                  <span class="rk-fstat"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 11.5A8.5 8.5 0 0 1 12.5 20a8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.5 8.5 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3 8.5 8.5 0 0 1 21 11.5z"/></svg>{p.comments}</span>
                  <span class="rk-fstat"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M9.5 9.5h4a2 2 0 0 1 0 4h-3.5"/></svg>{p.donations}</span>
                </span>
              </span>
            </li>
          ))}
        </ol>
      </section>

      <span class="rk-arrow" aria-hidden="true">→</span>

      <section class="rk-col rk-col-algo" aria-label="演算法序的首頁">
        <header class="rk-colhead">
          <span class="rk-colicon" aria-hidden="true">✨</span>
          <span class="rk-coltitle">演算法序</span>
          <span class="rk-colsub">互動高的浮上來</span>
        </header>
        <ol class="rk-feed" role="list">
          {byAlgo.map((p, i) => {
            const move = timeRank[p.id] - (i + 1); // >0 上升，<0 下降
            return (
              <li class={`rk-fcard${i === 0 ? ' is-algotop' : ''}`} data-id={p.id} data-move={move} role="listitem">
                <span class="rk-rank" aria-hidden="true">{rankGlyph[i]}</span>
                <span class="rk-fcard__body">
                  <span class="rk-fhead">
                    <span class="rk-favatar" style={`background:hsl(${p.hue} 55% 55%)`} aria-hidden="true">{p.author.slice(0, 1)}</span>
                    <span class="rk-fauthor">{p.author}</span>
                    <span class="rk-ftime">· {p.time}</span>
                    {move !== 0 && (
                      <span class={`rk-move ${move > 0 ? 'up' : 'down'}`} aria-label={`相較時間序${move > 0 ? '上升' : '下降'} ${Math.abs(move)} 名`}>
                        {move > 0 ? '▲' : '▼'}{Math.abs(move)}
                      </span>
                    )}
                  </span>
                  <span class="rk-ftitle">{p.title}</span>
                  <span class="rk-fmeta">
                    <span class="rk-fstat"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>{p.reads.toLocaleString()}</span>
                    <span class="rk-fstat rk-fstat--key"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 11.5A8.5 8.5 0 0 1 12.5 20a8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.5 8.5 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3 8.5 8.5 0 0 1 21 11.5z"/></svg>{p.comments}</span>
                    <span class="rk-fstat"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M9.5 9.5h4a2 2 0 0 1 0 4h-3.5"/></svg>{p.donations}</span>
                    <span class="rk-fscore" aria-label={`演算法分數 ${p.score.toFixed(2)}`}>{p.score.toFixed(2)}</span>
                  </span>
                </span>
              </li>
            );
          })}
        </ol>
      </section>
    </div>

    <p class="rk-legend" aria-hidden="true">
      同一則內容在兩欄的名次差，就是「誰決定你看見什麼」。
      <span class="rk-legtag up">▲ 被推上去</span>
      <span class="rk-legtag down">▼ 被壓下來</span>
      <span class="rk-legtag key">♡ 留言＝最重的權重</span>
    </p>
    <p class="rk-out" id="rk-out" aria-live="polite"></p>
  </div>
  <noscript><p class="rk-out">互動需 JavaScript。重點：分數＝0.3·閱讀＋0.4·留言＋0.3·打賞。留言權重最高，所以「能源政策的公共討論」（60 留言）會排在「爆紅迷因整理」（5000 閱讀）之前——演算法獎勵的是引發討論，不是純曝光。</p></noscript>
</div>

<style>
  .rk { max-width: 860px; margin: 0 auto; }
  .rk-q { text-align: center; font-size: 17px; }

  /* ── 上半：單欄 feed（ArticleCard），先猜 ── */
  .rk-cards { display: flex; flex-direction: column; gap: var(--space-sp10); max-width: 480px; margin: 0 auto; }
  .rk-card { display: flex; gap: var(--space-sp12); text-align: left; width: 100%;
    border: 1px solid var(--line); border-radius: var(--radius-card); padding: var(--space-sp14);
    background: #fff; cursor: pointer; font-family: var(--font-ui);
    box-shadow: var(--shadow-shadow1, 0 1px 4px rgba(0,0,0,.04)); transition: border-color .15s, transform .14s, box-shadow .14s; }
  .rk-card:hover { border-color: var(--c-brand, #7258FF); transform: translateY(-2px); box-shadow: var(--shadow-dropdown-new, 0 8px 22px rgba(0,0,0,.1)); }
  .rk-card.guess { border-color: var(--c-brand, #7258FF); box-shadow: 0 0 0 2px var(--c-brand, #7258FF); }
  .fi-avatar { flex: 0 0 auto; width: 34px; height: 34px; border-radius: 999px; color: #fff;
    display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 15px; }
  .fi-body { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .fi-head { display: flex; gap: 6px; align-items: baseline; font-size: 12.5px; color: var(--ink-soft); }
  .fi-author { font-weight: 700; color: var(--ink); }
  .fi-title { font-weight: 700; font-size: 15px; line-height: 1.45; color: var(--ink); }
  .fi-meta { display: flex; gap: var(--space-sp14); margin-top: 2px; }
  .fi-stat { display: inline-flex; align-items: center; gap: 4px; font-size: 12px; color: var(--ink-soft); }
  .fi-stat svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  /* ── 下半：揭曉。兩欄並列，各自一條真 feed ── */
  .rk-reveal { margin-top: 26px; }
  .rk-cols { display: grid; grid-template-columns: 1fr auto 1fr; align-items: start; gap: var(--space-sp14); }
  .rk-arrow { align-self: center; color: var(--c-brand, #7258FF); font-size: 22px; font-weight: 800; line-height: 1; padding-top: 30px; }

  .rk-col { min-width: 0; }
  .rk-colhead { display: flex; align-items: baseline; gap: 7px; padding: 0 4px 10px; flex-wrap: wrap; }
  .rk-colicon { font-size: 15px; }
  .rk-coltitle { font: 800 15px var(--font-ui); color: var(--ink); }
  .rk-colsub { font: 600 12px var(--font-ui); color: var(--ink-soft); }
  .rk-col-algo .rk-coltitle { color: var(--c-brand, #7258FF); }

  .rk-feed { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-sp10); }

  /* 玻璃感 Matters 貼文卡（對齊 .sg-card / .fp-card），左側帶名次徽章 */
  .rk-fcard { position: relative; display: flex; gap: 9px; align-items: flex-start;
    padding: 11px 13px 11px 11px; border-radius: 13px; font-family: var(--font-ui);
    background: rgba(255,255,255,.66); backdrop-filter: blur(9px); -webkit-backdrop-filter: blur(9px);
    border: 1px solid rgba(255,255,255,.66); box-shadow: 0 4px 16px rgba(22,18,45,.09);
    transition: border-color .18s, box-shadow .18s, transform .18s, filter .18s; }

  /* 名次徽章（①②③…）：時間序與演算法序各自的排名 */
  .rk-rank { flex: 0 0 auto; width: 24px; height: 24px; border-radius: 999px;
    display: flex; align-items: center; justify-content: center;
    font: 800 14px var(--font-ui); color: var(--ink-soft);
    background: rgba(120,115,140,.14); margin-top: 1px; font-variant-numeric: tabular-nums; }

  .rk-fcard__body { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; gap: 3px; }
  .rk-fhead { display: flex; align-items: center; gap: 5px; font-size: 12px; color: var(--ink-soft); min-width: 0; }
  .rk-favatar { flex: 0 0 auto; width: 20px; height: 20px; border-radius: 999px; color: #fff;
    font: 800 10px var(--font-ui); display: flex; align-items: center; justify-content: center; }
  .rk-fauthor { font: 700 12px var(--font-ui); color: var(--ink); white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; max-width: 7em; flex: 0 1 auto; }
  .rk-ftime { white-space: nowrap; flex: 0 0 auto; }
  .rk-ftitle { font: 700 13.5px/1.4 var(--font-ui); color: var(--ink);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .rk-fmeta { display: flex; align-items: center; gap: 10px; margin-top: 3px; flex-wrap: wrap; }
  .rk-fstat { display: inline-flex; align-items: center; gap: 3px; font: 600 11px var(--font-ui); color: var(--ink-soft); }
  .rk-fstat svg { width: 13px; height: 13px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  /* 留言＝最重權重，在演算法欄稍微強調 */
  .rk-fstat--key { color: var(--c-brand, #7258FF); font-weight: 800; }

  /* 演算法分數徽章 */
  .rk-fscore { margin-left: auto; flex: 0 0 auto; font: 800 11px var(--font-ui); font-variant-numeric: tabular-nums;
    color: var(--c-brand, #7258FF); background: color-mix(in srgb, var(--c-brand, #7258FF) 12%, transparent);
    padding: 2px 8px; border-radius: 999px; }

  /* 位移標：相較時間序上升/下降幾名 */
  .rk-move { flex: 0 0 auto; margin-left: auto; font: 800 10.5px var(--font-ui); font-variant-numeric: tabular-nums;
    padding: 1px 6px; border-radius: 999px; line-height: 1.5; }
  .rk-move.up { color: var(--c-pos, #5c9969); background: color-mix(in srgb, var(--c-pos, #5c9969) 15%, transparent); }
  .rk-move.down { color: var(--c-neg, #c85c41); background: color-mix(in srgb, var(--c-neg, #c85c41) 15%, transparent); }

  /* 演算法第一名：高亮 */
  .rk-fcard.is-algotop { border-color: var(--c-brand, #7258FF);
    box-shadow: 0 0 0 1.5px var(--c-brand, #7258FF), 0 8px 22px rgba(114,88,255,.18); }
  .rk-fcard.is-algotop .rk-rank { background: var(--c-brand, #7258FF); color: #fff; }

  /* hover/標記：把同一則內容在「兩欄」一起點亮，看出位置差 */
  .rk-fcard.is-link { border-color: var(--c-brand, #7258FF); box-shadow: 0 0 0 1.5px var(--c-brand, #7258FF), 0 6px 18px rgba(114,88,255,.16); }
  .rk-fcard.is-guess { border-color: var(--ink); box-shadow: 0 0 0 1.5px var(--ink); }
  .rk-fcard.is-guess .rk-rank { outline: 2px dotted var(--ink); outline-offset: 1px; }

  /* 圖例 */
  .rk-legend { text-align: center; font: 600 12.5px var(--font-ui); color: var(--ink-soft); margin: 16px auto 0;
    display: flex; flex-wrap: wrap; gap: 8px 14px; justify-content: center; align-items: center; max-width: 640px; }
  .rk-legtag { display: inline-flex; align-items: center; gap: 4px; font-weight: 700; padding: 1px 8px; border-radius: 999px; }
  .rk-legtag.up { color: var(--c-pos, #5c9969); background: color-mix(in srgb, var(--c-pos, #5c9969) 13%, transparent); }
  .rk-legtag.down { color: var(--c-neg, #c85c41); background: color-mix(in srgb, var(--c-neg, #c85c41) 13%, transparent); }
  .rk-legtag.key { color: var(--c-brand, #7258FF); background: color-mix(in srgb, var(--c-brand, #7258FF) 12%, transparent); }

  .rk-out { text-align: center; font-size: 16px; margin-top: 16px; }

  /* 手機左右滑提示（桌面隱藏）；base 放在 media 之前，手機 media 才能覆寫成 block */
  .rk-swipehint { display: none; text-align: center; font: 700 12.5px var(--font-ui); color: var(--ink-soft);
    margin: 0 0 10px; }
  .rk-swipehint span { color: var(--c-brand, #7258FF); }
  /* ── 手機：兩欄改「左右滑」比較（scroll-snap），一次看一欄、不上下堆 10 張卡；純 CSS、無需 JS ── */
  @media (max-width: 640px) {
    .rk-cols { display: flex; grid-template-columns: none; gap: 0; align-items: start;
      overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .rk-cols::-webkit-scrollbar { display: none; }
    .rk-col { flex: 0 0 100%; scroll-snap-align: center; min-width: 0; padding: 0 2px; }
    .rk-arrow { display: none; }
    .rk-swipehint { display: block; }
    /* 效能：去 backdrop-filter 改實底 */
    .rk-fcard { backdrop-filter: none; -webkit-backdrop-filter: none; background: rgba(255,255,255,.93); }
  }

  @media (prefers-reduced-motion: reduce) {
    .rk-card, .rk-fcard { transition: none; }
    .rk-card:hover { transform: none; }
  }
</style>

<script is:inline>
  (function () {
    var root = document.getElementById('rk-root');
    if (!root) return;
    var top = root.getAttribute('data-top');
    var cards = [].slice.call(root.querySelectorAll('.rk-card'));
    var reveal = document.getElementById('rk-reveal');
    var out = document.getElementById('rk-out');
    var fcards = [].slice.call(reveal.querySelectorAll('.rk-fcard'));
    var titles = {};
    cards.forEach(function (c) { titles[c.getAttribute('data-id')] = c.querySelector('.rk-title').textContent; });

    // 把同一則內容在兩欄一起點亮（連線高亮），看出名次差
    function link(id, on) {
      fcards.forEach(function (f) {
        if (f.getAttribute('data-id') === id) f.classList.toggle('is-link', on);
      });
    }
    fcards.forEach(function (f) {
      var id = f.getAttribute('data-id');
      f.addEventListener('mouseenter', function () { link(id, true); });
      f.addEventListener('mouseleave', function () { link(id, false); });
      // 鍵盤可達：卡片可聚焦並以 focus 觸發連線
      f.setAttribute('tabindex', '0');
      f.addEventListener('focus', function () { link(id, true); });
      f.addEventListener('blur', function () { link(id, false); });
    });

    cards.forEach(function (card) {
      card.addEventListener('click', function () {
        var guess = card.getAttribute('data-id');
        cards.forEach(function (c) { c.classList.toggle('guess', c === card); });
        reveal.hidden = false;
        // 標記：玩家猜的那則（兩欄都標），方便對照名次
        fcards.forEach(function (f) {
          f.classList.toggle('is-guess', f.getAttribute('data-id') === guess);
        });
        var correct = guess === top;
        out.innerHTML = (correct ? '猜對了！' : '你猜「' + titles[guess] + '」，但演算法把「' + titles[top] + '」排第一。')
          + ' 因為分數裡<strong>留言的權重最高（0.4）</strong>，演算法最想獎勵的是能「引發討論」的內容，曝光高低反而是其次。'
          + '所以 60 則留言的貼文，贏過 5000 次閱讀的爆紅迷因。';
        document.getElementById('rk-q').textContent = '時間序 vs 演算法序：同一批內容，兩種「誰被看見」。';
        reveal.scrollIntoView({ block: 'nearest' });
      });
    });
  })();
</script>
