---
// 招牌互動：集團偵測。16 張迷你 Matters 貼文卡排成 grid，
// 8 張「翻譯社」集團帳號用同一個模板（同標題、同版型，只有帳號名略不同）——
// 這個「長得一模一樣」的視覺本身就是證據。
//   ① 單篇模型偵測：只抓到 2 篇高分明顯垃圾，8 張集團卡因單篇分數太低漏網。
//   ② 集團偵測：用品牌紫圓角外框把 8 張集團卡框成一組（抓行為、不抓字句）。
// 卡片靜態渲染（Astro .map），scoped style 才套得到；JS 只加 class／量外框位置／播 GSAP。

// type: normal=正常（綠 accent） / spam=明顯垃圾（紅 accent） / ring=集團（翻譯社同模板）
// 排序＝DOM 順序＝grid 由左到右、由上到下；8 張 ring 必須「連續相鄰」（集團才框得起來）。
// 佈局：桌面 4 欄。前 8 格放 6 正常＋2 垃圾，後 8 格連續放集團卡（恰好下半部兩整列）。
type Post = { type: 'normal' | 'spam' | 'ring'; author: string; title: string; score: number };
const posts: Post[] = [
  // ── 上半部（前 8 格）：6 正常 + 2 明顯垃圾，穿插混在一起 ──
  { type: 'normal', author: '黃柏勳', title: '清晨六點的傳統市場：攤販叫賣聲的田野筆記', score: 0.07 },
  { type: 'normal', author: '蘇怡安', title: '為什麼咖啡冷掉會變酸？從萃取曲線聊起', score: 0.05 },
  { type: 'spam',   author: '財神娛樂城', title: '【註冊送888】老虎機爆分實測，出金秒到帳', score: 0.96 },
  { type: 'normal', author: '鄭家瑋', title: '重看《一一》：楊德昌拍的是我們每個人的客廳', score: 0.12 },
  { type: 'normal', author: '李宛庭', title: '我的書架很亂，但每一格都記得：談個人藏書整理', score: 0.09 },
  { type: 'spam',   author: '草本養生堂', title: '純天然三天根治高血壓，無效退費（限量）', score: 0.99 },
  { type: 'normal', author: '王思博', title: '海邊撿來的玻璃：一場關於潮汐與耐心的小科普', score: 0.20 },
  { type: 'normal', author: '吳采蓁', title: '台南老屋改建札記：那道捨不得拆的磨石子樓梯', score: 0.11 },
  // ── 下半部（後 8 格，連續相鄰）：翻譯社集團，標題「完全相同」，只有帳號名略不同 ──
  { type: 'ring', author: '宏達翻譯社',     title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', score: 0.10 },
  { type: 'ring', author: '達宏翻譯工作室', title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', score: 0.08 },
  { type: 'ring', author: '宏翻達譯社',     title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', score: 0.11 },
  { type: 'ring', author: '達宏翻譯有限公司', title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', score: 0.09 },
  { type: 'ring', author: '宏達譯社',       title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', score: 0.12 },
  { type: 'ring', author: '翻譯達人宏達',   title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', score: 0.08 },
  { type: 'ring', author: '宏達學術翻譯',   title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', score: 0.10 },
  { type: 'ring', author: '達宏論文潤稿',   title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', score: 0.11 },
];

// 頭像底色（穩定指派，不寫死語意色；對齊 StickyScroller 的柔和色盤）
const avPalette = ['#7a7390', '#b07a4a', '#6f8f4e', '#5a8a93', '#a8597a', '#8a6db0'];
const initials = (name: string) => name.slice(0, 1);
const INIT_READOUT = '下面 16 張是社群裡的貼文，每張角落是它「單篇內容」的垃圾分數。先按「單篇模型偵測」，再按「集團偵測」，比較兩者各抓到什麼。';
---
<div class="rd" id="ring-root">
  <div class="rd-stage" id="rd-stage">
    <div class="rd-grid" id="rd-grid">
      {posts.map((p, i) => (
        <article class={`rd-card rd-${p.type}`} data-i={i} data-type={p.type} data-score={p.score}>
          <header class="rd-card__head">
            <span class="rd-av" style={`background:${avPalette[i % avPalette.length]}`}>{initials(p.author)}</span>
            <span class="rd-author">{p.author}</span>
            <span class="rd-more" aria-hidden="true">⋯</span>
          </header>
          <h3 class="rd-title">{p.title}</h3>
          <div class="rd-summary" aria-hidden="true">
            <span class="sk sk-line"></span>
            <span class="sk sk-line sk-line--short"></span>
          </div>
          <footer class="rd-card__foot">
            <span class="sk sk-meta" aria-hidden="true"></span>
            <span class="rd-score" title="單篇垃圾分數">分數 {p.score.toFixed(2)}</span>
          </footer>
        </article>
      ))}
    </div>
    {/* 集團外框＋標籤：JS 量「8 張集團卡外接框」定位，absolute 疊在 grid 上、不擋點擊 */}
    <div class="rd-frame" id="rd-frame" aria-hidden="true"></div>
    <div class="rd-frame-label" id="rd-frame-label" aria-hidden="true">同一模板 ×8｜多帳號｜短時間</div>
  </div>

  <div class="rd-controls">
    <button type="button" id="ring-btn-single">① 單篇模型偵測</button>
    <button type="button" id="ring-btn-ring">② 集團偵測</button>
    <button type="button" id="ring-btn-reset" class="rd-reset">重置</button>
  </div>
  <p class="rd-readout" id="ring-readout" aria-live="polite">{INIT_READOUT}</p>
  <noscript><p class="rd-readout">互動需 JavaScript。重點：8 個「翻譯社」帳號用同一模板洗版，標題一模一樣；但每篇單看分數只有 0.08–0.12，單篇模型幾乎漏抓。集團偵測靠「同模板、多帳號、短時間」的行為樣態，整群一次抓。</p></noscript>
</div>

<style>
  .rd { max-width: 660px; margin: 0 auto; }
  /* stage：給外框與其標籤足夠 padding，框與標籤絕不被裁切 */
  .rd-stage { position: relative; padding: 20px; background: var(--bg-paper); border: 1px solid var(--line);
    border-radius: 16px; overflow: visible; }

  /* 16 張卡的 grid：桌面 4 欄、手機 2 欄；集團 8 張在後半連續兩列。
     用 minmax(0,1fr)（非 1fr＝minmax(auto,1fr)）：欄寬不被卡片內容(作者名等)的 min-content 撐爆，
     四欄永遠等寬、不溢出容器；卡內文字靠既有 ellipsis/line-clamp 收斂。 */
  .rd-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }

  /* ── 迷你 Matters 貼文卡（對齊 StickyScroller .sg-card 玻璃語言，更精簡：無封面縮圖）── */
  .rd-card { position: relative; border-radius: 12px; padding: 11px 12px; color: var(--ink);
    font-family: var(--font-ui); background: rgba(255,255,255,.72);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,.7); box-shadow: 0 3px 12px rgba(22,18,45,.08);
    transition: opacity .35s, box-shadow .35s, border-color .35s, transform .35s; }
  /* 左側 accent 邊條：正常＝土綠 / 垃圾＝土紅 / 集團平時也算垃圾色（單篇仍是垃圾，只是低分） */
  .rd-card::before { content: ''; position: absolute; left: 0; top: 9px; bottom: 9px; width: 3px; border-radius: 3px; }
  .rd-normal::before { background: var(--c-pos, #5c9969); }
  .rd-spam::before, .rd-ring::before { background: var(--c-neg, #c85c41); }

  .rd-card__head { display: flex; align-items: center; gap: 6px; }
  .rd-av { flex: 0 0 auto; width: 20px; height: 20px; border-radius: 50%; color: #fff;
    font: 800 10px var(--font-ui); display: flex; align-items: center; justify-content: center; }
  .rd-author { font: 700 11.5px var(--font-ui); color: var(--ink); white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; min-width: 0; }
  .rd-more { margin-left: auto; color: var(--ink-soft); font-weight: 700; letter-spacing: 1px; line-height: 1; flex: 0 0 auto; }
  .rd-title { margin: 7px 0 8px; font: 700 12.5px/1.5 var(--font-ui); color: var(--ink);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.6em; }
  .rd-summary { display: flex; flex-direction: column; gap: 5px; margin-bottom: 9px; }
  .rd-card__foot { display: flex; align-items: center; gap: 8px; }

  /* 灰骨架（暫代摘要／meta，對齊 .sk） */
  .sk { background: rgba(120,115,140,.18); border-radius: 5px; display: inline-block; }
  .sk-line { height: 8px; width: 100%; }
  .sk-line--short { width: 60%; }
  .sk-meta { width: 26px; height: 8px; border-radius: 99px; flex: 0 0 auto; }

  /* 分數徽章 */
  .rd-score { margin-left: auto; font: 700 10.5px var(--font-ui); color: var(--ink-soft);
    background: rgba(120,115,140,.12); padding: 2px 8px; border-radius: 999px; white-space: nowrap; flex: 0 0 auto;
    transition: color .35s, background .35s; }

  /* ── 狀態：變淡（沒被這次偵測命中／非焦點） ── */
  .rd-card.dim { opacity: .32; }

  /* ── 狀態：單篇命中（高分明顯垃圾，紅框點亮＋紫脈動） ── */
  .rd-card.hit { opacity: 1; border-color: var(--c-neg, #c85c41);
    box-shadow: 0 0 0 2px var(--c-neg, #c85c41), 0 8px 22px rgba(160,60,40,.22); }
  .rd-card.hit .rd-score { color: #fff; background: var(--c-neg, #c85c41); }
  .rd-card.hit::after { content: '垃圾'; position: absolute; top: -8px; right: 8px; z-index: 3;
    font: 800 10px var(--font-ui); color: #fff; background: var(--c-neg, #c85c41);
    padding: 2px 8px; border-radius: 999px; box-shadow: 0 3px 10px rgba(160,60,40,.3); }
  /* 紫脈動環（偵測信號色） */
  .rd-pulse { position: absolute; inset: -3px; border-radius: 14px; pointer-events: none;
    border: 2px solid var(--accent, #7258FF); opacity: 0; }

  /* ── 狀態：被集團框住（整群一夥的，紫色信號描邊） ── */
  .rd-card.ringed { opacity: 1; border-color: color-mix(in srgb, var(--accent, #7258FF) 55%, transparent);
    box-shadow: 0 0 0 1.5px color-mix(in srgb, var(--accent, #7258FF) 35%, transparent), 0 6px 18px rgba(70,50,160,.16); }

  /* ── 集團外框（JS 量集團 8 張外接框定位）：品牌紫圓角＋虛線＋淡紫填充 ── */
  .rd-frame { position: absolute; z-index: 2; opacity: 0; pointer-events: none; border-radius: 16px;
    border: 2.5px dashed var(--accent, #7258FF);
    background: color-mix(in srgb, var(--accent, #7258FF) 7%, transparent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent, #7258FF) 12%, transparent), 0 10px 30px rgba(70,50,160,.2);
    transform-box: border-box; transform-origin: center; transform: scale(.6); }
  .rd-frame.show { opacity: 1; transform: scale(1); }
  /* 標籤 chip：疊在外框上緣，絕不被裁（stage overflow:visible + padding） */
  .rd-frame-label { position: absolute; z-index: 4; transform: translate(-50%, 0); opacity: 0; pointer-events: none;
    font: 800 12px var(--font-ui); color: #fff; white-space: nowrap; background: var(--accent, #7258FF);
    padding: 4px 12px; border-radius: 999px; box-shadow: 0 4px 12px rgba(70,50,160,.35); transition: opacity .3s; }
  .rd-frame-label.show { opacity: 1; }

  .rd-controls { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin: 16px 0 8px; }
  .rd-controls button { font: 700 14px var(--font-ui); padding: 8px 16px; border-radius: 999px;
    border: 1.5px solid var(--accent, #7258FF); background: #fff; color: var(--accent, #7258FF); cursor: pointer;
    transition: background .15s, color .15s; }
  .rd-controls button:hover { background: var(--accent, #7258FF); color: #fff; }
  .rd-controls .rd-reset { border-color: var(--line); color: var(--ink-soft); }
  .rd-controls .rd-reset:hover { background: var(--line); color: var(--ink); }
  .rd-readout { text-align: center; font-size: 16px; min-height: 3.4em; max-width: 560px; margin: 0 auto; line-height: 1.7; }

  /* ── 響應式：手機 2 欄（集團 8 張改成連續 4 列、仍然相鄰一整塊） ── */
  @media (max-width: 680px) {
    .rd-stage { padding: 16px; }
    .rd-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
    .rd-title { font-size: 12px; -webkit-line-clamp: 3; min-height: 0; }
    .rd-frame-label { font-size: 11px; padding: 3px 10px; }
    .rd-readout { font-size: 15px; }
    /* 觸控目標 ≥44px */
    .rd-controls button { min-height: 44px; padding: 10px 18px; }
  }

  /* 偏好減少動態：直接呈現最終狀態，不播放過場 */
  @media (prefers-reduced-motion: reduce) {
    .rd-card, .rd-score, .rd-frame, .rd-frame-label { transition: none; }
    .rd-frame.show { transform: scale(1); }
  }
</style>

<script>
  import gsap from 'gsap';

  function initRing() {
    const root = document.getElementById('ring-root');
    if (!root || root.dataset.ringInit === '1') return;
    root.dataset.ringInit = '1';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const stage = document.getElementById('rd-stage');
    const grid = document.getElementById('rd-grid');
    const frame = document.getElementById('rd-frame');
    const frameLabel = document.getElementById('rd-frame-label');
    const out = document.getElementById('ring-readout');
    const INIT_READOUT = '下面 16 張是社群裡的貼文，每張角落是它「單篇內容」的垃圾分數。先按「單篇模型偵測」，再按「集團偵測」，比較兩者各抓到什麼。';

    const cards = Array.prototype.slice.call(grid.querySelectorAll('.rd-card'));
    const ringCards = cards.filter((c) => c.getAttribute('data-type') === 'ring');
    const spamCards = cards.filter((c) => c.getAttribute('data-type') === 'spam');

    // 把紫色外框定位到「8 張集團卡的外接矩形」（相對 stage，量 getBoundingClientRect）
    function placeFrame() {
      if (!ringCards.length) return;
      const sr = stage.getBoundingClientRect();
      let top = Infinity, bottom = -Infinity, left = Infinity, right = -Infinity;
      ringCards.forEach((c) => {
        const r = c.getBoundingClientRect();
        top = Math.min(top, r.top); bottom = Math.max(bottom, r.bottom);
        left = Math.min(left, r.left); right = Math.max(right, r.right);
      });
      const pad = 8;
      const fl = (left - sr.left) - pad;
      const ft = (top - sr.top) - pad;
      const fw = (right - left) + pad * 2;
      const fh = (bottom - top) + pad * 2;
      gsap.set(frame, { left: fl, top: ft, width: fw, height: fh });
      gsap.set(frameLabel, { left: fl + fw / 2, top: ft - 30 });
    }

    function killPulses() {
      cards.forEach((c) => {
        const p = c.querySelector('.rd-pulse');
        if (p) { gsap.killTweensOf(p); p.remove(); }
      });
    }

    function clear() {
      killPulses();
      cards.forEach((c) => c.classList.remove('dim', 'hit', 'ringed'));
      if (frame) { frame.classList.remove('show'); gsap.set(frame, { clearProps: 'transform,opacity' }); }
      if (frameLabel) frameLabel.classList.remove('show');
    }

    function pulse(card) {
      if (reduce) return;
      const p = document.createElement('span');
      p.className = 'rd-pulse';
      card.appendChild(p);
      gsap.fromTo(p,
        { opacity: .85, scale: 1 },
        { opacity: 0, scale: 1.18, duration: 1.1, ease: 'power2.out', repeat: -1, repeatDelay: .35,
          transformOrigin: 'center center' });
    }

    // ① 單篇模型：只有 2 張高分垃圾被命中（紅框點亮＋脈動），其餘變淡；集團卡因低分漏網
    document.getElementById('ring-btn-single').addEventListener('click', () => {
      clear();
      cards.forEach((c) => {
        const s = parseFloat(c.getAttribute('data-score'));
        if (s >= 0.7) { c.classList.add('hit'); pulse(c); }
        else { c.classList.add('dim'); }
      });
      out.innerHTML = '單篇模型抓到 <b>' + spamCards.length + ' 篇</b>明顯垃圾，卻<b>漏掉 ' + ringCards.length +
        ' 個「翻譯社」集團帳號</b>：它們每篇分數只有 0.08–0.12，單看就像正常內容。';
    });

    // ② 集團偵測：8 張集團卡被品牌紫外框框成一組（back.out 彈入），加標籤，其餘變淡
    document.getElementById('ring-btn-ring').addEventListener('click', () => {
      clear();
      cards.forEach((c) => {
        if (c.getAttribute('data-type') === 'ring') c.classList.add('ringed');
        else c.classList.add('dim');
      });
      placeFrame();

      if (reduce) {
        frame.classList.add('show');
        gsap.set(frame, { opacity: 1, scale: 1 });
        frameLabel.classList.add('show');
      } else {
        frame.classList.add('show');
        gsap.fromTo(frame, { opacity: 0, scale: .6 },
          { opacity: 1, scale: 1, duration: .6, ease: 'back.out(1.7)' });
        ringCards.forEach((c, i) => gsap.delayedCall(.25 + i * 0.05, () => pulse(c)));
        frameLabel.classList.add('show');
        gsap.fromTo(frameLabel, { opacity: 0, y: 6 }, { opacity: 1, y: 0, duration: .4, ease: 'power2.out', delay: .4 });
      }

      out.innerHTML = '集團偵測：同一模板、<b>' + ringCards.length + ' 個帳號</b>、在短時間內重複出現，' +
        '靠的是<b>整群帳號的行為模式</b>，一次就掃掉。這正是單篇模型抓不到的盲區。';
    });

    document.getElementById('ring-btn-reset').addEventListener('click', () => {
      clear();
      out.textContent = INIT_READOUT;
    });

    // resize 時若外框正顯示，重算位置
    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => { if (frame.classList.contains('show')) placeFrame(); }, 200);
    });
  }

  // 首頁與 detection 頁皆需成立；Astro view transitions 也重跑
  if (document.readyState !== 'loading') initRing();
  else document.addEventListener('DOMContentLoaded', initRing);
  document.addEventListener('astro:page-load', initRing);
</script>
