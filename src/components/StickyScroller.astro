---
// 招牌：sticky scrollytelling（GSAP ScrollTrigger 連續 timeline 版）。
// 同一條 feed：正常→垃圾飛入淹沒→過濾飛出→誤殺(放慢推近)→集團(三卡聚攏成同一模板疊放)→收束。
// 黑/光脊椎：滿版暗幕用 multiply 乾淨變暗，feed 在暗中發光。CSS sticky 釘住；no-JS/reduced-motion 退靜態。
const cards = [
  { kind: 'green',  label: '政治評論' },
  { kind: 'green',  label: '學術考據' },
  { kind: 'green',  label: '日記' },
  { kind: 'green',  label: '時事' },
  { kind: 'green',  label: '知識科普' },
  { kind: 'green',  label: '書評' },
  { kind: 'green',  label: '藝文' },
  { kind: 'green',  label: '一首詩' },
  { kind: 'red',    label: '賭場' },
  { kind: 'red',    label: '外送茶' },
  { kind: 'red',    label: 'SEO 農場' },
  { kind: 'red',    label: '賣藥' },
  { kind: 'red',    label: '二次詐騙' },
  { kind: 'red',    label: 'MLM' },
  { kind: 'border', label: '人權議題' },
  { kind: 'border', label: '文學創作' },
  { kind: 'border', label: '防詐科普' },
  { kind: 'ring',   label: '翻譯社' },
  { kind: 'ring',   label: '翻譯社' },
  { kind: 'ring',   label: '翻譯社' },
];
const steps = [
  { text: '假設完全沒有審查，你看得到所有內容。一開始，都是正常用戶寫的東西——綠色。' },
  { text: '但垃圾也一起湧進來。色情、賭博、詐騙、內容農場……每 5 篇就有 4 篇是這種紅色。沒有審查，公共首頁會被淹沒到無法閱讀。' },
  { text: '模型給每篇打一個垃圾分數，分數高的被擋下——紅色被抽走，首頁恢復乾淨。注意：不是刪除，只是不再被看見。' },
  { text: '但有些正常內容分數也很高：人權議題、文學創作、防詐科普。它們被一起誤殺了——這就是偽陽性，被誤殺的往往正是最該保護的表達。' },
  { text: '還有一種垃圾分數很低、漏了網——但它們是同一模板、大量帳號的「集團」。靠行為（不靠字句）一網打盡。' },
  { text: '這就是審查在做的事，以及它為什麼難：在擋垃圾與不誤殺之間，反覆校準同一條分數線。' },
];
---
<div class="scrolly" id="scrolly">
  <div class="scrolly-atmos" id="scrolly-atmos" aria-hidden="true"></div>
  <div class="scrolly-grid">
    <div class="scrolly-figwrap">
      <div class="scrolly-fig" id="sg" data-state="green">
        <div class="sg-stage" id="sg-stage">
          <div class="sg-glow" id="sg-glow" aria-hidden="true"></div>
          <div class="sg-feed" id="sg-feed">
            {cards.map((c) => (
              <div class={`sg-card sg-${c.kind}`} data-kind={c.kind}>
                <span>{c.label}</span>
                {c.kind === 'border' && <i class="sg-tag sg-tag-kill" aria-hidden="true">誤殺</i>}
              </div>
            ))}
          </div>
          <div class="sg-line" id="sg-line" aria-hidden="true"></div>
          <div class="sg-ring-halo" id="sg-ring-halo" aria-hidden="true"></div>
          <div class="sg-ring-label" id="sg-ring-label" aria-hidden="true">集團 · 同一模板 ×3</div>
        </div>
        <p class="sg-cap" id="sg-cap">正常用戶的內容</p>
      </div>
    </div>
    <div class="scrolly-steps">
      {steps.map((s, i) => (
        <div class="scrolly-step" data-i={i}><p>{s.text}</p></div>
      ))}
    </div>
  </div>
</div>

<style>
  .scrolly { position: relative; width: min(1080px, 96vw); margin-left: 50%; transform: translateX(-50%); }
  .scrolly-atmos { position: absolute; top: 0; bottom: 0; left: 50%; transform: translateX(-50%); width: 100vw;
    z-index: 0; opacity: 0; pointer-events: none; mix-blend-mode: multiply;
    background: radial-gradient(130% 82% at 50% 40%, #4b4570 0%, #221c44 52%, #0e0b22 100%); }
  .scrolly-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
  .scrolly-figwrap { position: sticky; top: 0; height: 100vh; display: flex; align-items: center; }
  .scrolly-fig { position: relative; width: 100%; background: var(--bg-paper); border: 1px solid var(--line); border-radius: 18px;
    padding: 18px; box-shadow: 0 8px 30px rgba(40,36,30,.07); will-change: background-color; }
  .sg-stage { position: relative; }
  /* feed 在暗場中的柔光（spotlight，暗時才亮） */
  .sg-glow { position: absolute; left: 50%; top: 50%; width: 116%; height: 128%; transform: translate(-50%, -50%);
    z-index: 0; opacity: 0; pointer-events: none; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(255,251,242,.9), rgba(255,251,242,0)); filter: blur(8px); }
  .sg-feed { position: relative; z-index: 1; display: flex; flex-wrap: wrap; gap: 7px; justify-content: center; align-content: center; min-height: 320px; }
  .sg-card { position: relative; width: 88px; height: 50px; border-radius: 9px; border: 1.5px solid; display: flex;
    align-items: center; justify-content: center; font: 700 12px var(--font-ui); text-align: center; padding: 2px;
    overflow: hidden; white-space: nowrap; will-change: transform, opacity; }
  .sg-green, .sg-border { background: #eef2e3; border-color: #6f8f4e; color: #3f4a2c; }
  .sg-red, .sg-ring { background: #f6e6e1; border-color: #c0584a; color: #6e2c23; }
  .sg-tag { position: absolute; bottom: 1px; right: 3px; font: 700 8px var(--font-ui); opacity: 0; pointer-events: none; }
  .sg-tag-kill { color: #c0584a; }
  .sg-line { position: absolute; left: 0; right: 0; top: 50%; height: 2px; transform: scaleX(0); transform-origin: left center;
    background: linear-gradient(90deg, transparent, var(--c-brand, #7258FF) 20%, var(--c-brand, #7258FF) 80%, transparent);
    opacity: .85; border-radius: 2px; z-index: 2; }
  /* 集團聚攏的光暈與標籤（JS 定位到三卡形心） */
  .sg-ring-halo { position: absolute; width: 200px; height: 132px; transform: translate(-50%, -50%) scale(.55);
    z-index: 1; opacity: 0; pointer-events: none; border-radius: 50%;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--c-brand, #7258FF) 42%, transparent), transparent);
    filter: blur(5px); }
  .sg-ring-label { position: absolute; transform: translate(-50%, 0); z-index: 5; opacity: 0; pointer-events: none;
    font: 800 13px var(--font-ui); color: #fff; white-space: nowrap; background: var(--c-brand, #7258FF);
    padding: 3px 11px; border-radius: 999px; box-shadow: 0 4px 12px rgba(70,50,160,.35); }
  .sg-cap { text-align: center; font: 700 15px var(--font-ui); margin: 16px 0 0; color: var(--ink); min-height: 1.4em; }

  .scrolly-step { min-height: 90vh; display: flex; align-items: center; }
  .scrolly-step:first-child { min-height: 55vh; }
  .scrolly-step[data-i="3"] { min-height: 140vh; } /* 誤殺高潮：拉長、放慢 */
  .scrolly-step[data-i="4"] { min-height: 110vh; } /* 集團：給聚攏動畫空間 */
  .scrolly-step:last-child { min-height: 80vh; }
  .scrolly-step p { font-size: 20px; line-height: 1.9; background: #fff; border: 1px solid var(--line);
    padding: 16px 20px; border-radius: 14px; box-shadow: 0 4px 18px rgba(40,36,30,.06); opacity: .55;
    transition: opacity .4s, transform .4s, border-color .4s; }
  html.js .scrolly-step p { opacity: .35; transform: translateY(6px); }
  html.js .scrolly-step.active p { opacity: 1; transform: none; border-color: color-mix(in srgb, var(--c-brand, #7258FF) 35%, var(--line)); }

  @media (max-width: 720px) {
    .scrolly { width: 100%; margin-left: 0; transform: none; }
    .scrolly-grid { grid-template-columns: 1fr; gap: 0; }
    .scrolly-figwrap { height: 48vh; top: 54px; }
    .sg-feed { min-height: 0; }
    .sg-card { width: 72px; height: 42px; font-size: 11px; }
    .scrolly-step { min-height: 70vh; }
    .scrolly-step[data-i="3"] { min-height: 100vh; }
    .scrolly-step p { font-size: 18px; }
  }

  html:not(.js) .scrolly-step p { opacity: 1; }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initScrolly() {
    const sg = document.getElementById('sg');
    if (!sg || sg.dataset.inited) return;
    sg.dataset.inited = '1';

    const fig = sg;
    const feed = document.getElementById('sg-feed');
    const cap = document.getElementById('sg-cap');
    const line = document.getElementById('sg-line');
    const atmos = document.getElementById('scrolly-atmos');
    const glow = document.getElementById('sg-glow');
    const halo = document.getElementById('sg-ring-halo');
    const ringLabel = document.getElementById('sg-ring-label');
    const steps = Array.prototype.slice.call(document.querySelectorAll('#scrolly .scrolly-step'));
    const all = Array.prototype.slice.call(feed.querySelectorAll('.sg-card'));
    const pick = (k) => all.filter((c) => c.getAttribute('data-kind') === k);
    const green = pick('green'), red = pick('red'), border = pick('border'), ring = pick('ring');
    const killTags = Array.prototype.slice.call(feed.querySelectorAll('.sg-tag-kill'));
    const caps = [
      '正常用戶的內容', '垃圾湧入，淹沒首頁', '模型把高分的擋下',
      '但高分的正常內容也被誤殺', '低分集團：同一模板、大量帳號', '一條分數線，反覆校準',
    ];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // 三張集團卡「聚攏成疊放扇形」的位移（在任何 transform 之前算自然位置）
    function computeGather() {
      const fr = feed.getBoundingClientRect();
      const rc = ring.map((c) => {
        const r = c.getBoundingClientRect();
        return { cx: r.left - fr.left + r.width / 2, cy: r.top - fr.top + r.height / 2 };
      });
      const ctr = {
        x: (rc[0].cx + rc[1].cx + rc[2].cx) / 3,
        y: (rc[0].cy + rc[1].cy + rc[2].cy) / 3,
      };
      const SPX = [-40, 0, 40], SPY = [10, -10, 10], ROT = [-9, 0, 9];
      const g = ring.map((c, i) => ({ x: (ctr.x + SPX[i]) - rc[i].cx, y: (ctr.y + SPY[i]) - rc[i].cy, rot: ROT[i] }));
      return { g, ctr };
    }
    const { g: gather, ctr } = computeGather();
    // 光暈與標籤定位到三卡形心
    gsap.set(halo, { left: ctr.x, top: ctr.y });
    gsap.set(ringLabel, { left: ctr.x, top: ctr.y + 52 });

    function setActive(i) {
      steps.forEach((s, j) => s.classList.toggle('active', j === i));
      if (caps[i]) cap.textContent = caps[i];
    }

    if (reduce) {
      gsap.set(red, { opacity: 0.16, filter: 'grayscale(1)', scale: 0.85 });
      gsap.set(border, { backgroundColor: '#e7e3d8', borderColor: '#c0584a', color: '#9a958a' });
      gsap.set(killTags, { opacity: 1 });
      ring.forEach((c, i) => gsap.set(c, { x: gather[i].x, y: gather[i].y, rotation: gather[i].rot, scale: 1.12, zIndex: 20 + (i === 1 ? 3 : i) }));
      gsap.set([halo, ringLabel], { opacity: 1 });
      gsap.set(halo, { scale: 1 });
      steps.forEach((s) => s.classList.add('active'));
      return;
    }

    gsap.set([...red, ...border, ...ring], { opacity: 0, scale: 0.4, yPercent: 45 });
    gsap.set(green, { opacity: 1, scale: 1, yPercent: 0 });
    gsap.set(atmos, { opacity: 0 });
    gsap.set(glow, { opacity: 0 });

    const tl = gsap.timeline({
      defaults: { ease: 'power2.out' },
      scrollTrigger: { trigger: '#scrolly', start: 'top top', end: 'bottom bottom', scrub: 1 },
    });

    tl.to({}, { duration: 0.55 }); // 0 綠色保持

    // 1 淹沒
    tl.addLabel('flood');
    tl.to([...red, ...border, ...ring], {
      opacity: 1, scale: 1, yPercent: 0, duration: 0.9,
      stagger: { each: 0.022, from: 'random' }, ease: 'back.out(1.5)',
    }, 'flood');
    tl.to(fig, { backgroundColor: '#efe4dd', borderColor: '#d8c4bb', duration: 0.9 }, 'flood');

    // 2 過濾：分界線掃過、紅卡向上飛出並塌縮
    tl.addLabel('filter');
    tl.fromTo(line, { scaleX: 0 }, { scaleX: 1, duration: 0.4, ease: 'power1.inOut' }, 'filter');
    tl.to(red, {
      yPercent: -120, opacity: 0, rotation: () => gsap.utils.random(-14, 14),
      width: 0, minWidth: 0, paddingLeft: 0, paddingRight: 0, marginLeft: -3.5, marginRight: -3.5, borderWidth: 0,
      duration: 0.8, stagger: 0.04, ease: 'power2.in',
    }, 'filter+=0.12');
    tl.to(fig, { backgroundColor: '#f7f6f2', borderColor: '#e8e5de', duration: 0.7 }, 'filter+=0.2');
    tl.to(line, { opacity: 0, duration: 0.3 }, 'filter+=0.6');

    // 3 誤殺（高潮，放慢）
    tl.addLabel('fp');
    tl.to(border[0], { scale: 1.22, duration: 0.45, ease: 'power2.out' }, 'fp+=0.1');
    tl.to(border[0], { scale: 1, duration: 0.35 }, 'fp+=0.7');
    tl.to(border, { backgroundColor: '#e7e3d8', borderColor: '#c0584a', color: '#9a958a', duration: 0.6, stagger: 0.1 }, 'fp+=0.25');
    tl.to(killTags, { opacity: 1, duration: 0.3, stagger: 0.1 }, 'fp+=0.5');
    tl.to({}, { duration: 0.5 });

    // 4 集團：其餘退暗聚光，三張翻譯社聚攏成「同一模板」疊放扇形 + 光暈 + 標籤
    tl.addLabel('ring');
    tl.to([...green, ...border], { opacity: 0.28, duration: 0.45 }, 'ring');
    ring.forEach((c, i) => {
      tl.to(c, {
        x: gather[i].x, y: gather[i].y, rotation: gather[i].rot, scale: 1.14,
        zIndex: 20 + (i === 1 ? 3 : i), duration: 0.65, ease: 'power3.inOut',
      }, 'ring');
    });
    tl.to(halo, { opacity: 1, scale: 1, duration: 0.5 }, 'ring+=0.15');
    tl.to(ringLabel, { opacity: 1, duration: 0.4 }, 'ring+=0.35');

    // 5 收束：其餘卡片回來一些、整體微縮靜下
    tl.addLabel('settle');
    tl.to([...green, ...border], { opacity: 0.62, duration: 0.5 }, 'settle');
    tl.to(feed, { scale: 0.97, duration: 0.5, ease: 'power1.inOut' }, 'settle');

    // 黑/光脊椎（multiply 乾淨變暗）＋ feed 暗中發光的 spotlight
    tl.to(atmos, { opacity: 0.5, duration: 0.9 }, 'flood');
    tl.to(glow, { opacity: 0.5, duration: 0.9 }, 'flood');
    tl.to(atmos, { opacity: 0.74, duration: 0.8 }, 'filter');
    tl.to(atmos, { opacity: 0.82, duration: 0.8 }, 'fp+=0.1');
    tl.to(glow, { opacity: 0.85, duration: 0.8 }, 'fp+=0.1');
    tl.to(atmos, { opacity: 0.6, duration: 0.5 }, 'ring');
    tl.to(atmos, { opacity: 0.16, duration: 0.5 }, 'settle');
    tl.to(glow, { opacity: 0, duration: 0.5 }, 'settle');

    steps.forEach((step, i) => {
      ScrollTrigger.create({
        trigger: step, start: 'top 55%', end: 'bottom 55%',
        onToggle: (self) => { if (self.isActive) setActive(i); },
      });
    });
    setActive(0);

    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => { ScrollTrigger.refresh(); }, 200);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrolly);
  } else {
    initScrolly();
  }
  document.addEventListener('astro:page-load', initScrolly);
</script>
