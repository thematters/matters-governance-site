---
// 招牌：sticky scrollytelling（GSAP ScrollTrigger 連續 timeline 版）— D1 階段二。
// 單欄垂直 feed，真 Matters 貼文卡（ArticleCard 版型），可忽略欄位用灰色半透明骨架暫代。
// 整條 feed 隨捲動往上 translateY（像滑社群）；同一條 feed 走：
//   正常 → 垃圾「已隱藏」覆蓋層淹沒 → 過濾(紅卡壓暗) → 誤刪(邊界好內容紅框) → 集團(三張翻譯社紫框框成一組) → 收束。
// 黑/光脊椎：滿版暗幕用 multiply 乾淨變暗，feed 在暗中發光。CSS sticky 釘住；no-JS/reduced-motion 退靜態可讀。

// kind: green=正常 / red=垃圾 / border=邊界好內容(被誤刪) / ring=集團(翻譯社同模板)
// 順序＝DOM 順序＝feed 由上往下；三張 ring 必須連續（集團才框得起來）。
const posts = [
  // ── 開場：良善的小天地（一批綠色好文先進入；像真 Matters 文章、中性不說教）──
  { kind: 'green',  author: '黃柏勳', title: '清晨六點的傳統市場：一份關於攤販叫賣聲的田野筆記', time: '2 小時前', reads: '1.5k', comments: 39, appr: 162 },
  { kind: 'green',  author: '蘇怡安', title: '為什麼咖啡冷掉之後會變酸？從萃取曲線聊起', time: '4 小時前', reads: '2.3k', comments: 58, appr: 244 },
  { kind: 'green',  author: '鄭家瑋', title: '重看《一一》：原來楊德昌拍的是我們每個人的客廳', time: '7 小時前', reads: '3.1k', comments: 91, appr: 338 },
  { kind: 'green',  author: '張哲睿', title: '台南老屋改建札記（三）：那道捨不得拆的磨石子樓梯', time: '9 小時前', reads: '1.1k', comments: 27, appr: 118 },
  { kind: 'green',  author: '李宛庭', title: '我的書架很亂，但每一格都記得：談個人藏書的整理哲學', time: '昨天', reads: '986', comments: 33, appr: 142 },
  { kind: 'green',  author: '王思博', title: '海邊撿來的玻璃：一場關於潮汐、時間與耐心的小科普', time: '昨天', reads: '1.7k', comments: 44, appr: 201 },
  { kind: 'green',  author: '何明軒', title: '當「公共討論」變成情緒勞動：談演算法時代的對話倫理', time: '3 小時前', reads: '1.2k', comments: 48, appr: 132 },
  { kind: 'green',  author: '林書宇', title: '考據：日治時期台北城內的書店地圖（上）', time: '5 小時前', reads: '864', comments: 21, appr: 97 },
  { kind: 'red',    author: '財神娛樂城', title: '【註冊送888】今晚不睡也要贏！老虎機爆分實測，出金秒到帳', time: '1 分鐘前', reads: '12', comments: 0, appr: 1 },
  { kind: 'green',  author: '吳采蓁', title: '六月病房日記：陪母親化療的第十四天', time: '8 小時前', reads: '2.1k', comments: 73, appr: 256 },
  { kind: 'red',    author: '草本養生堂', title: '純天然！三天根治高血壓糖尿病，無效退費（限量）', time: '2 分鐘前', reads: '34', comments: 1, appr: 0 },
  { kind: 'green',  author: '陳怡蓁', title: '從一場罷工說起：我們其實不太懂什麼叫團結', time: '昨天', reads: '3.4k', comments: 112, appr: 401 },
  { kind: 'red',    author: '李專員', title: '您的包裹清關失敗，點我重新驗證並補繳關稅以免退回', time: '剛剛', reads: '8', comments: 0, appr: 0 },
  { kind: 'border', author: '緬甸觀察筆記', title: '被消失的人們：克欽邦良民證制度下的無國籍世代', time: '6 小時前', reads: '1.8k', comments: 54, appr: 188 },
  { kind: 'red',    author: 'SEO快速排名工作室', title: '關鍵字三天上首頁｜外鏈代發｜流量包月｜加賴詳談', time: '5 分鐘前', reads: '19', comments: 0, appr: 0 },
  { kind: 'border', author: '夜行短篇', title: '〈渡口〉：一則關於離開與留下的微型小說', time: '11 小時前', reads: '742', comments: 33, appr: 119 },
  { kind: 'border', author: '反詐騙小教室', title: '拆解「假投資真詐騙」：六個你該立刻掛電話的訊號', time: '1 天前', reads: '5.6k', comments: 201, appr: 612 },
  { kind: 'ring',   author: '宏達翻譯有限公司', title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', time: '4 分鐘前', reads: '23', comments: 0, appr: 0 },
  { kind: 'ring',   author: '達宏翻譯工作室', title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', time: '4 分鐘前', reads: '17', comments: 0, appr: 0 },
  { kind: 'ring',   author: '宏翻達譯社', title: '【專業論文翻譯】中英互譯｜母語潤稿｜當天交件，價格優惠', time: '6 分鐘前', reads: '21', comments: 0, appr: 0 },
];

// 頭像底色（穩定指派，不寫死語意色號的 magic — 用一組柔和色盤）
const avPalette = ['#7a7390', '#b07a4a', '#6f8f4e', '#5a8a93', '#a8597a', '#8a6db0'];
const initials = (name: string) => name.slice(0, 1);

// 敘事步驟文字（與 caps/timeline label 對應）
const steps = [
  { text: '社群平台剛起步的時候，首頁通常是一片良善的小天地：一篇篇貼文進來，有生活觀察、地方紀錄、影評書評，都是正常使用者寫給彼此看的東西。' },
  { text: '但人一變多，垃圾內容也跟著湧進來。賭場、賣藥、詐騙、內容農場，這些貼文混進正常內容之間，目的只有一個：騙人，或騙流量。' },
  { text: '把畫面倒回去，做個思想實驗：假設這個平台完全不做任何審查，每一篇貼進來的東西都會原封不動出現在首頁上。' },
  { text: '結果很快就很難看：「註冊送 888」「純天然根治」這類貼文沒人攔，數量又遠多過正常內容，幾小時內就把首頁灌爆，真正想讀的東西全被推到看不到的地方。' },
  { text: '模型給每篇打一個垃圾分數，分數高的就被擋下，蓋上「已隱藏」。注意，這不是刪除，只是不再被看見。' },
  { text: '但有些正常內容分數也很高，像人權議題、文學創作、防詐科普，結果一起被誤刪了。這正是偽陽性，而被誤殺的，往往就是最該保護的表達。' },
  { text: '還有一種垃圾分數很低、漏了網：三家「翻譯社」用幾乎一樣的模板大量發文。要靠它們的行為模式，才認得出這是一個集團。' },
  { text: '審查做的就是這件事，難也難在這裡：在「擋垃圾」和「別誤殺」之間，反覆微調同一條分數線。' },
];
---
<div class="scrolly" id="scrolly">
  <div class="scrolly-atmos" id="scrolly-atmos" aria-hidden="true"></div>
  <div class="scrolly-grid">
    <div class="scrolly-figwrap">
      <div class="scrolly-fig" id="sg" data-state="green">
        <div class="sg-stage" id="sg-stage">
          <div class="sg-glow" id="sg-glow" aria-hidden="true"></div>
          <div class="sg-viewport" id="sg-viewport">
            <div class="sg-feed" id="sg-feed">
              {posts.map((p, i) => (
                <article class={`sg-card sg-${p.kind}`} data-kind={p.kind} data-i={i}>
                  <div class="sg-card__main">
                    <header class="sg-card__head">
                      <span class="sg-av" style={`background:${avPalette[i % avPalette.length]}`}>{initials(p.author)}</span>
                      <span class="sg-author">{p.author}</span>
                      <span class="sg-dot" aria-hidden="true">·</span>
                      <span class="sk sk-time" aria-hidden="true"></span>
                      <span class="sg-more" aria-hidden="true">⋯</span>
                    </header>
                    <h3 class="sg-title">{p.title}</h3>
                    <div class="sg-summary" aria-hidden="true">
                      <span class="sk sk-line"></span>
                      <span class="sk sk-line sk-line--short"></span>
                    </div>
                    <footer class="sg-card__foot">
                      <span class="sg-metric"><i aria-hidden="true">👁</i>{p.reads}</span>
                      <span class="sg-metric"><i aria-hidden="true">♡</i>{p.appr}</span>
                      <span class="sg-metric"><i aria-hidden="true">💬</i>{p.comments}</span>
                      <span class="sk sk-meta" aria-hidden="true"></span>
                      <span class="sk sk-meta sk-meta--wide" aria-hidden="true"></span>
                    </footer>
                  </div>
                  <div class="sg-cover sk" aria-hidden="true"></div>
                  {p.kind === 'red' && <div class="sg-hidden" aria-hidden="true"><span>已隱藏</span></div>}
                  {p.kind === 'border' && <i class="sg-tag sg-tag-kill" aria-hidden="true">誤刪</i>}
                </article>
              ))}
            </div>
          </div>
          <div class="sg-ring-frame" id="sg-ring-frame" aria-hidden="true"></div>
          <div class="sg-ring-label" id="sg-ring-label" aria-hidden="true">集團 · 同一模板 ×3</div>
        </div>
        <p class="sg-cap" id="sg-cap">正常使用者的內容</p>
        <!-- 手機浮層字幕：浮在全螢幕 feed 底部、tab bar 之上；由 JS 寫入當前 active 步驟全文 -->
        <p class="sg-narrate" id="sg-narrate" aria-hidden="true"></p>
        <!-- 擬真社群 app 底部 tab bar（手機才顯示，純裝飾／aria-hidden，賣「我在滑真 app」的沉浸感） -->
        <nav class="sg-tabbar" aria-hidden="true">
          <svg viewBox="0 0 24 24" class="is-on"><path d="M3 11l9-7 9 7v9a1 1 0 0 1-1 1h-5v-6h-6v6H4a1 1 0 0 1-1-1z"/></svg>
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3.6-3.6"/></svg>
          <svg viewBox="0 0 24 24" class="sg-tabbar__add"><circle cx="12" cy="12" r="9"/><path d="M12 8v8M8 12h8"/></svg>
          <svg viewBox="0 0 24 24"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 8-3 8h18s-3-1-3-8z"/><path d="M10.5 21a2 2 0 0 0 3 0"/></svg>
          <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6 8-6s8 2 8 6"/></svg>
        </nav>
      </div>
    </div>
    <div class="scrolly-steps">
      {steps.map((s, i) => (<div class="scrolly-step" data-i={i}><p>{s.text}</p></div>))}
    </div>
  </div>
</div>

<style>
  .scrolly { position: relative; width: min(1080px, 96vw); margin-left: 50%; transform: translateX(-50%); }
  .scrolly-atmos { position: absolute; top: 0; bottom: 0; left: 50%; transform: translateX(-50%); width: 100vw;
    z-index: 0; opacity: 0; pointer-events: none; mix-blend-mode: multiply;
    background: radial-gradient(130% 82% at 50% 40%, #4b4570 0%, #221c44 52%, #0e0b22 100%); }
  .scrolly-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
  .scrolly-figwrap { position: sticky; top: 0; height: 100vh; display: flex; align-items: center; }
  .scrolly-fig { position: relative; width: 100%; border-radius: 20px; padding: 16px;
    background: rgba(255,255,255,.5); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,.65); box-shadow: 0 14px 44px rgba(18,14,45,.18); }
  /* 玻璃 app 框頂部小列（社群平台感） */
  .sg-stage::before { content: ''; display: block; height: 8px; width: 54px; margin: -2px auto 12px;
    border-radius: 99px; background: rgba(120,110,160,.28); }
  .sg-stage { position: relative; }
  /* feed 在暗場中的柔光（spotlight，暗時才亮） */
  .sg-glow { position: absolute; left: 50%; top: 50%; width: 116%; height: 122%; transform: translate(-50%, -50%);
    z-index: 0; opacity: 0; pointer-events: none; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(255,251,242,.9), rgba(255,251,242,0)); filter: blur(8px); }

  /* 單欄 feed：viewport 只露出約 3–4 張卡，feed 整條隨捲動往上跑 */
  .sg-viewport { position: relative; z-index: 1; height: min(62vh, 520px); overflow: hidden;
    -webkit-mask-image: linear-gradient(180deg, transparent 0, #000 9%, #000 91%, transparent 100%);
    mask-image: linear-gradient(180deg, transparent 0, #000 9%, #000 91%, transparent 100%); }
  .sg-feed { display: flex; flex-direction: column; gap: 12px; align-items: center; will-change: transform;
    padding: 6px 0; }

  /* ── Matters ArticleCard 版型（單欄、置中、max-width ~380） ── */
  .sg-card { position: relative; width: min(380px, 100%); border-radius: 14px; overflow: hidden;
    display: flex; gap: 12px; padding: 13px 14px; color: var(--ink); font-family: var(--font-ui);
    background: rgba(255,255,255,.72); backdrop-filter: blur(9px); -webkit-backdrop-filter: blur(9px);
    border: 1px solid rgba(255,255,255,.7); box-shadow: 0 4px 16px rgba(22,18,45,.1);
    will-change: transform, opacity; }
  .sg-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; }
  .sg-green::before, .sg-border::before { background: var(--c-pos, #5c9969); }
  .sg-red::before,   .sg-ring::before   { background: var(--c-neg, #c85c41); }

  .sg-card__main { flex: 1 1 auto; min-width: 0; }
  .sg-card__head { display: flex; align-items: center; gap: 7px; }
  .sg-av { flex: 0 0 auto; width: 22px; height: 22px; border-radius: 50%; color: #fff;
    font: 800 11px var(--font-ui); display: flex; align-items: center; justify-content: center; }
  .sg-author { font: 700 12.5px var(--font-ui); color: var(--ink); white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; max-width: 9.5em; }
  .sg-dot { color: var(--ink-soft); font-size: 12px; flex: 0 0 auto; }
  .sg-more { margin-left: auto; color: var(--ink-soft); font-weight: 700; letter-spacing: 1px;
    flex: 0 0 auto; line-height: 1; }
  .sg-title { margin: 7px 0 8px; font: 700 14.5px/1.45 var(--font-ui); color: var(--ink);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .sg-summary { display: flex; flex-direction: column; gap: 5px; margin-bottom: 11px; }
  .sg-card__foot { display: flex; align-items: center; gap: 12px; }
  .sg-metric { display: inline-flex; align-items: center; gap: 4px; font: 600 11.5px var(--font-ui);
    color: var(--ink-soft); flex: 0 0 auto; }
  .sg-metric i { font-style: normal; font-size: 11px; opacity: .8; }

  /* 右側封面縮圖（骨架暫代） */
  .sg-cover { flex: 0 0 auto; width: 62px; height: 62px; border-radius: 9px; align-self: flex-start; margin-top: 1px; }

  /* ── 灰色半透明骨架塊（可忽略欄位：time / 摘要 / 封面 / 次要 meta） ── */
  .sk { background: rgba(120,115,140,.18); border-radius: 5px; display: inline-block; }
  .sk-time { width: 42px; height: 9px; }
  .sk-line { height: 9px; width: 100%; }
  .sk-line--short { width: 64%; }
  .sk-meta { width: 30px; height: 9px; border-radius: 99px; }
  .sk-meta--wide { width: 46px; }

  /* ── 敘事狀態：垃圾「已隱藏」覆蓋層 ── */
  .sg-hidden { position: absolute; inset: 0; z-index: 4; display: flex; align-items: center; justify-content: center;
    background: rgba(58,54,74,.62); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
    opacity: 0; pointer-events: none; }
  .sg-hidden span { font: 800 13px var(--font-ui); color: rgba(255,255,255,.92); letter-spacing: .06em;
    padding: 4px 14px; border: 1.5px solid rgba(255,255,255,.5); border-radius: 999px; }

  /* ── 敘事狀態：誤刪標 ── */
  .sg-tag { position: absolute; top: 9px; right: 11px; z-index: 5; font: 800 10px var(--font-ui);
    color: #fff; background: var(--c-neg, #c85c41); padding: 2px 8px; border-radius: 999px;
    opacity: 0; pointer-events: none; box-shadow: 0 3px 10px rgba(160,60,40,.3); }

  /* ── 敘事狀態：集團紫框 + 標籤（JS 定位框住連續三張） ── */
  .sg-ring-frame { position: absolute; z-index: 3; opacity: 0; pointer-events: none; border-radius: 16px;
    border: 2.5px solid var(--c-brand, #7258FF); box-shadow: 0 0 0 4px color-mix(in srgb, var(--c-brand, #7258FF) 16%, transparent),
      0 10px 30px rgba(70,50,160,.25); }
  .sg-ring-label { position: absolute; transform: translate(-50%, 0); z-index: 5; opacity: 0; pointer-events: none;
    font: 800 13px var(--font-ui); color: #fff; white-space: nowrap; background: var(--c-brand, #7258FF);
    padding: 3px 12px; border-radius: 999px; box-shadow: 0 4px 12px rgba(70,50,160,.35); }

  .sg-cap { text-align: center; font: 700 15px var(--font-ui); margin: 14px 0 0; color: var(--ink); min-height: 1.4em; }
  /* 首頁暗色舞台：StickyScroller 落在第一章 N1 暗底上，loose 標題轉白 */
  :global(.dark-stage) .sg-cap { color: #fff; text-shadow: 0 1px 10px rgba(0,0,0,.6); }

  /* 手機浮層字幕（桌面隱藏）：浮在全螢幕 feed 底部、tab bar 之上，半透明暗底＋白字 */
  .sg-narrate { display: none; position: absolute; left: 14px; right: 14px; bottom: 76px; z-index: 6;
    margin: 0; font: 500 15.5px/1.7 var(--font-ui); color: #fff; text-align: left;
    background: rgba(16,14,28,.82); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.18); box-shadow: 0 12px 34px rgba(0,0,0,.5);
    padding: 13px 16px; border-radius: 16px; }
  @media (prefers-reduced-motion: no-preference) { .sg-narrate { transition: opacity .3s ease; } }

  /* 擬真 app 底部 tab bar（桌面隱藏，手機在全螢幕 feed 底部顯示） */
  .sg-tabbar { display: none; position: absolute; left: 0; right: 0; bottom: 0; z-index: 5;
    align-items: center; justify-content: space-around; height: 54px; padding: 0 10px;
    background: rgba(14,12,26,.82); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border-top: 1px solid rgba(255,255,255,.12); }
  .sg-tabbar svg { width: 24px; height: 24px; fill: none; stroke: rgba(255,255,255,.72);
    stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  .sg-tabbar svg.is-on { fill: #fff; stroke: #fff; }
  .sg-tabbar svg.sg-tabbar__add { stroke: var(--c-brand, #7258FF); width: 30px; height: 30px; stroke-width: 1.6; }

  .scrolly-step { min-height: 90vh; display: flex; align-items: center; }
  .scrolly-step:first-child { min-height: 55vh; }
  .scrolly-step[data-i="0"] { min-height: 70vh; } /* 良善小天地：開場，給綠好文進場空間 */
  .scrolly-step[data-i="1"] { min-height: 80vh; } /* 垃圾湧入：紅貼文淡入 */
  .scrolly-step[data-i="5"] { min-height: 140vh; } /* 誤刪高潮：拉長、放慢 */
  .scrolly-step[data-i="6"] { min-height: 110vh; } /* 集團：給框住動畫空間 */
  .scrolly-step:last-child { min-height: 80vh; }
  .scrolly-step p { font-size: 20px; line-height: 1.9; background: #fff; border: 1px solid var(--line);
    padding: 16px 20px; border-radius: 14px; box-shadow: 0 4px 18px rgba(40,36,30,.06); opacity: .55;
    transition: opacity .4s, transform .4s, border-color .4s; }
  html.js .scrolly-step p { opacity: .35; transform: translateY(6px); }
  html.js .scrolly-step.active p { opacity: 1; transform: none; border-color: color-mix(in srgb, var(--c-brand, #7258FF) 35%, var(--line)); }

  /* ── 手機（≤720px）：scrollytelling 改「全螢幕擬真 feed ＋ 浮層字幕」──
     桌面雙欄(視覺＋旁白)在手機水土不服(注意力被撕兩半)；手機改成 feed 滿版釘住整屏
     (去玻璃框/去上下淡出條)，旁白做成半透明字幕卡浮在 feed 下方、隨捲動切換、與畫面同框。 */
  @media (max-width: 720px) {
    /* 滿版到螢幕邊（突破 .container 左右 padding；用 margin 不用 transform，才不破壞 sticky）
       → feed 與底部 tab bar 都寬度佔滿、邊到邊 */
    .scrolly { width: 100vw; margin-left: calc(50% - 50vw); transform: none; }
    .scrolly-grid { display: block; }
    /* feed 滿版釘住整屏（去框、去淡出條） */
    .scrolly-figwrap { position: sticky; top: 0; height: 100svh; padding: 0; display: block; }
    .scrolly-fig { background: none; border: none; box-shadow: none; backdrop-filter: none;
      -webkit-backdrop-filter: none; padding: 0; border-radius: 0; height: 100%; }
    .sg-stage { height: 100%; }
    .sg-stage::before { display: none; }
    .sg-viewport { height: 100svh; -webkit-mask-image: none; mask-image: none; }
    .sg-feed { padding: 12vh 0 26vh; }
    .sg-card { width: min(440px, 88vw); }
    .sg-cap { display: none; }
    .sg-tabbar { display: flex; }
    .sg-narrate { display: block; }
    /* 旁白：右欄文字在手機隱藏，步驟只當「隱形捲動間距」驅動既有 ScrollTrigger；
       實際字幕由 JS 寫進 .sg-narrate(浮在 feed 底部、tab bar 之上)，與畫面同框、不再並排。 */
    .scrolly-steps { position: relative; z-index: 1; padding: 0; }
    /* 步驟＝隱形捲動間距：收短，避免手機要滑太久才換字幕／到下一段（原 ~8 屏 → ~5 屏） */
    .scrolly-step { min-height: 58svh; display: block; }
    .scrolly-step:first-child { min-height: 44svh; }
    .scrolly-step[data-i="5"] { min-height: 82svh; }
    .scrolly-step[data-i="6"] { min-height: 74svh; }
    .scrolly-step p { display: none; }
  }

  /* no-JS：feed 整條可讀（不裁切）、步驟全顯示；手機把釘住/隱形步驟還原成可讀靜態流，藏掉 JS 才有意義的浮層字幕與裝飾 tab bar */
  html:not(.js) .scrolly-step p { opacity: 1; display: block; }
  html:not(.js) .sg-viewport { height: auto; -webkit-mask-image: none; mask-image: none; }
  html:not(.js) .scrolly-figwrap { position: static; height: auto; }
  html:not(.js) .sg-narrate, html:not(.js) .sg-tabbar { display: none; }

  /* 手機 + 偏好減少動態：JS reduced-motion 分支不跑 scrub/字幕，故還原成靜態可讀流（feed 在上、步驟文字在下），
     不用釘住全螢幕＋空浮層字幕。 */
  @media (max-width: 720px) and (prefers-reduced-motion: reduce) {
    .scrolly-figwrap { position: static; height: auto; }
    .sg-viewport { height: auto; }
    .sg-narrate, .sg-tabbar { display: none; }
    .scrolly-step { min-height: 0; padding: 8px 14px 18px; }
    .scrolly-step p { display: block; font-size: 16px; line-height: 1.7; background: rgba(255,255,255,.6);
      color: var(--ink); border: 1px solid var(--line); opacity: 1; }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initScrolly() {
    const sg = document.getElementById('sg');
    if (!sg || sg.dataset.inited) return;
    sg.dataset.inited = '1';

    const feed = document.getElementById('sg-feed');
    const viewport = document.getElementById('sg-viewport');
    const cap = document.getElementById('sg-cap');
    const narrate = document.getElementById('sg-narrate'); // 手機浮層字幕（桌面隱藏）
    const atmos = document.getElementById('scrolly-atmos');
    const glow = document.getElementById('sg-glow');
    const ringFrame = document.getElementById('sg-ring-frame');
    const ringLabel = document.getElementById('sg-ring-label');
    const steps = Array.prototype.slice.call(document.querySelectorAll('#scrolly .scrolly-step'));
    const all = Array.prototype.slice.call(feed.querySelectorAll('.sg-card'));
    const pick = (k) => all.filter((c) => c.getAttribute('data-kind') === k);
    const green = pick('green'), red = pick('red'), border = pick('border'), ring = pick('ring');
    const hiddenOverlays = (sel) => sel.map((c) => c.querySelector('.sg-hidden')).filter(Boolean);
    const killTags = border.map((c) => c.querySelector('.sg-tag-kill')).filter(Boolean);
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const caps = [
      '良善的小天地', '垃圾開始湧入',
      '正常使用者的內容', '垃圾湧入，淹沒首頁', '模型把高分的擋下',
      '但高分的正常內容也被誤刪', '低分集團：同一模板、大量帳號', '一條分數線，反覆校準',
    ];

    // feed 整條可往上捲的總距離：feed 高度 − viewport 高度（留一點 padding）
    function feedTravel() {
      return Math.max(0, feed.scrollHeight - viewport.clientHeight + 24);
    }

    // 把紫框定位到「連續三張 ring 卡」的外接框（相對 sg-stage）
    function placeRingFrame() {
      const stage = document.getElementById('sg-stage');
      const sr = stage.getBoundingClientRect();
      let top = Infinity, bottom = -Infinity, left = Infinity, right = -Infinity;
      ring.forEach((c) => {
        const r = c.getBoundingClientRect();
        top = Math.min(top, r.top); bottom = Math.max(bottom, r.bottom);
        left = Math.min(left, r.left); right = Math.max(right, r.right);
      });
      const pad = 7;
      gsap.set(ringFrame, {
        left: (left - sr.left) - pad, top: (top - sr.top) - pad,
        width: (right - left) + pad * 2, height: (bottom - top) + pad * 2,
      });
      gsap.set(ringLabel, { left: (left - sr.left + (right - left) / 2), top: (top - sr.top) - pad - 28 });
    }

    let lastCapText = '';
    function setCaption(text) {
      if (text === lastCapText) return;
      lastCapText = text;
      if (reduce) { cap.textContent = text; return; }
      cap.textContent = '';
      const spans = text.split('').map((ch) => {
        const s = document.createElement('span');
        s.textContent = ch === ' ' ? ' ' : ch;
        s.style.display = 'inline-block';
        cap.appendChild(s); return s;
      });
      gsap.fromTo(spans, { opacity: 0, yPercent: 60 },
        { opacity: 1, yPercent: 0, duration: 0.45, stagger: 0.018, ease: 'power2.out', overwrite: true });
    }
    function setActive(i) {
      steps.forEach((s, j) => s.classList.toggle('active', j === i));
      if (caps[i]) setCaption(caps[i]);
      // 手機浮層字幕：寫入當前步驟全文（桌面 .sg-narrate 隱藏，不影響）
      if (narrate && steps[i]) {
        const sp = steps[i].querySelector('p');
        if (sp) narrate.textContent = sp.textContent;
      }
    }

    // ── reduced-motion：直接顯示最終狀態，feed 捲到能看見集團，靜態可讀 ──
    // 開場「綠多→紅進來」的意思在靜態下也成立：綠好文在頂、紅垃圾全可見並被壓暗，
    // 集團紫框與誤刪標都落定，整條 feed 一眼讀完。
    if (reduce) {
      gsap.set([...red, ...ring], { opacity: 1 }); // 垃圾（含漏網集團）全部現身
      gsap.set(red, { filter: 'grayscale(1) brightness(.9)' });
      gsap.set(hiddenOverlays(red), { opacity: 1 });
      gsap.set(border, { boxShadow: '0 0 0 2px var(--c-neg, #c85c41)' });
      gsap.set(killTags, { opacity: 1 });
      gsap.set(feed, { y: -feedTravel() });
      placeRingFrame();
      gsap.set([ringFrame, ringLabel], { opacity: 1 });
      steps.forEach((s) => s.classList.add('active'));
      return;
    }

    // 初始：feed 在頂、暗幕/光暈關閉；垃圾（紅）與漏網集團（ring）先隱形，
    // 開場只見綠好文與邊界好內容（border 屬於良善小天地，從頭就在）。
    gsap.set(feed, { y: 0 });
    gsap.set(atmos, { opacity: 0 });
    gsap.set(glow, { opacity: 0 });
    gsap.set([...red, ...ring], { opacity: 0 });

    const tl = gsap.timeline({
      defaults: { ease: 'power2.out' },
      scrollTrigger: { trigger: '#scrolly', start: 'top top', end: 'bottom bottom', scrub: 1 },
    });

    // ── 開場序曲（PRE 秒）：在既有 flood 之前插入兩個 beat。──
    // PRE 把既有的 flood/filter/fp/ring/settle 整段往後平移同樣秒數，
    // 既有相對節奏與 feed「捲到底再停住」的關係完全保留（feed 於 PRE+6 抵達底部，
    // 恰在 filter 之前，與原本 6 之於 6.55 同構）。
    const PRE = 2.0;

    // 整條 feed 隨捲動往上跑（貫穿序曲＋原本行程，像滑社群）——比敘事更線性
    tl.fromTo(feed, { y: 0 }, { y: () => -feedTravel(), duration: PRE + 6, ease: 'none' }, 0);

    // beat 0 良善小天地：只見綠好文（與 border 好內容）進入，atmos 維持很亮（≈0）。
    tl.addLabel('welcome', 0);
    tl.to({}, { duration: 0.9 }, 'welcome'); // 純保持：讓綠好文先捲一段

    // beat 1 垃圾湧入：紅色垃圾（與漏網集團 ring）開始淡入混進來，atmos 輕微上升。
    tl.addLabel('influx', 0.95);
    tl.to(red, { opacity: 1, duration: 0.75, stagger: { each: 0.07, from: 'start' } }, 'influx');
    tl.to(ring, { opacity: 1, duration: 0.75, stagger: { each: 0.07, from: 'start' } }, 'influx+=0.2');
    tl.to(atmos, { opacity: 0.14, duration: 0.9, ease: 'power1.inOut' }, 'influx');

    tl.to({}, { duration: 0.55 }); // 收束序曲（與既有節奏對齊）

    // 1 淹沒：垃圾貼文（紅）滑到偵測時被標「已隱藏」覆蓋層淡入、卡片變暗壓扁一點
    tl.addLabel('flood', PRE + 0.55);
    tl.to(hiddenOverlays(red), { opacity: 1, duration: 0.7, stagger: { each: 0.05, from: 'random' } }, 'flood');
    tl.to(red, { filter: 'grayscale(.6) brightness(.94)', duration: 0.7, stagger: { each: 0.05, from: 'random' } }, 'flood');

    // 2 過濾：紅卡進一步壓暗/壓扁（單欄不飛出，改用壓縮高度＋變灰；不再用紫色橫掃線）
    tl.addLabel('filter');
    tl.to(red, { filter: 'grayscale(1) brightness(.86)', scaleY: 0.9, opacity: 0.85, duration: 0.7, stagger: 0.04 }, 'filter+=0.12');

    // 3 誤刪（高潮，放慢）：邊界好內容紅框高亮 + 「誤刪」標
    tl.addLabel('fp');
    tl.to(border[0], { scale: 1.06, boxShadow: '0 0 0 2px var(--c-neg, #c85c41), 0 14px 34px rgba(160,50,40,.3)', zIndex: 6, duration: 0.45 }, 'fp+=0.1');
    tl.to(border[0], { scale: 1, duration: 0.35 }, 'fp+=0.7');
    tl.to(border, { boxShadow: '0 0 0 2px var(--c-neg, #c85c41), 0 6px 18px rgba(160,50,40,.18)', duration: 0.6, stagger: 0.1 }, 'fp+=0.25');
    tl.to(killTags, { opacity: 1, duration: 0.3, stagger: 0.1 }, 'fp+=0.5');
    tl.to({}, { duration: 0.5 });

    // 4 集團：其餘退暗，紫框框住連續三張翻譯社 + 「集團 ×3」標
    tl.addLabel('ring');
    tl.add(() => placeRingFrame(), 'ring'); // 框前先量位置（前面 transform 不改版面，安全）
    tl.to([...green, ...border, ...red], { opacity: 0.32, duration: 0.45 }, 'ring');
    tl.to(ring, { opacity: 1, scale: 1.02, duration: 0.5 }, 'ring');
    tl.fromTo(ringFrame, { opacity: 0, scale: 0.96 }, { opacity: 1, scale: 1, duration: 0.5, transformOrigin: 'center center', ease: 'back.out(1.4)' }, 'ring+=0.1');
    tl.to(ringLabel, { opacity: 1, duration: 0.4 }, 'ring+=0.3');

    // 5 收束：其餘回來一些、整體微縮靜下
    tl.addLabel('settle');
    tl.to([...green, ...border, ...red], { opacity: 0.62, duration: 0.5 }, 'settle');
    tl.to(feed, { scale: 0.99, transformOrigin: 'center center', duration: 0.5, ease: 'power1.inOut' }, 'settle');

    // 黑/光脊椎（multiply 乾淨變暗）＋ feed 暗中發光的 spotlight
    tl.to(atmos, { opacity: 0.5, duration: 0.9 }, 'flood');
    tl.to(glow, { opacity: 0.5, duration: 0.9 }, 'flood');
    tl.to(atmos, { opacity: 0.74, duration: 0.8 }, 'filter');
    tl.to(atmos, { opacity: 0.82, duration: 0.8 }, 'fp+=0.1');
    tl.to(glow, { opacity: 0.85, duration: 0.8 }, 'fp+=0.1');
    tl.to(atmos, { opacity: 0.6, duration: 0.5 }, 'ring');
    tl.to(atmos, { opacity: 0.16, duration: 0.5 }, 'settle');
    tl.to(glow, { opacity: 0, duration: 0.5 }, 'settle');

    steps.forEach((step, i) => {
      ScrollTrigger.create({
        trigger: step, start: 'top 55%', end: 'bottom 55%',
        onToggle: (self) => { if (self.isActive) setActive(i); },
      });
    });
    setActive(0);

    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => { placeRingFrame(); ScrollTrigger.refresh(); }, 200);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrolly);
  } else {
    initScrolly();
  }
  document.addEventListener('astro:page-load', initScrolly);
</script>
