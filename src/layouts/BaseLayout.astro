---
import '@matters/design-system-tokens/tokens.css';
import '../styles/global.css';
import AudienceToggle from '../components/AudienceToggle.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const {
  title,
  description = '以 Matters 自身的治理史為案例，科普垃圾審查、排序演算法與抗審查。',
  lang = 'zh-Hant',
} = Astro.props;

// Pages 子路徑：用 <base href> + 相對連結（detection、en/…），不寫死前導斜線。
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const sections = [
  { href: 'detection', label: '偵測' },
  { href: 'false-positive', label: '偽陽性' },
  { href: 'ranking', label: '排序' },
  { href: 'censorship-resistance', label: '抗審查' },
  { href: 'history', label: '治理史' },
  { href: 'start', label: '全部主題' },
];
const path = Astro.url.pathname.replace(/\/$/, '');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <base href={base} />
    <script is:inline>document.documentElement.classList.add('js')</script>
    <title>{title}｜Matters 平台治理</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(base + 'illustrations/og.jpg', Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;800&family=Noto+Serif+TC:wght@400;600;700&display=swap"
    />
  </head>
  <body>
    <div id="progress"></div>

    <header class="site-header">
      <nav class="nav">
        <a class="brand" href={base}>透明開盒 <small>· Matters 平台治理</small></a>
        <span class="nav-spacer"></span>
        <div class="nav-links">
          {sections.map((s) => (
            <a href={s.href} aria-current={path.endsWith('/' + s.href) ? 'page' : undefined}>{s.label}</a>
          ))}
        </div>
        <AudienceToggle />
        <a class="nav-links" href="en/" style="text-decoration:none;color:var(--ink-soft);font-size:14px;">EN</a>
      </nav>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          <strong>審查還是抗審查？網路平台「透明開盒」的兩難</strong><br />
          TWNIC 社群計畫結案網站 · 以 Matters.town 為案例的平台治理科普
        </p>
        <p class="note">
          程式碼 MIT／文件 CC BY 4.0／研究資料依敏感度授權 ·
          本站規劃部署於 IPFS：網域被封，內容指紋仍在。
        </p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var bar = document.getElementById('progress');
        function onScroll() {
          var h = document.documentElement;
          var max = h.scrollHeight - h.clientHeight;
          var p = max > 0 ? (h.scrollTop / max) * 100 : 0;
          bar.style.width = p + '%';
        }
        document.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
