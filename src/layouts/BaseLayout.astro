---
import '@matters/design-system-tokens/tokens.css';
import '../styles/global.css';
import '../styles/ds.css';
import AudienceToggle from '../components/AudienceToggle.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const {
  title,
  description = '以 Matters 自身的治理史為案例，科普垃圾審查、排序演算法與抗審查。',
  lang = 'zh-Hant',
} = Astro.props;
// 注意：<title>{expr}文字</title> 在 Astro 的 RCDATA 會吞掉運算式後的文字，故組成單一字串
const fullTitle = `${title}｜Matters 平台小教室`;

// Pages 子路徑：用 <base href> + 相對連結（detection、en/…），不寫死前導斜線。
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const sections = [
  { href: 'detection', label: '偵測' },
  { href: 'false-positive', label: '偽陽性' },
  { href: 'ranking', label: '排序' },
  { href: 'censorship-resistance', label: '抗審查' },
  { href: 'history', label: '治理史' },
];
const path = Astro.url.pathname.replace(/\/$/, '');
const navLinksHtml = sections
  .map((s) => `<li><a href="${s.href}"${path.endsWith('/' + s.href) ? ' aria-current="page"' : ''}>${s.label}</a></li>`)
  .join('');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <base href={base} />
    <link rel="icon" type="image/svg+xml" href={base + 'matters-logo-graph.svg'} />
    <script is:inline>document.documentElement.classList.add('js')</script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(base + 'illustrations/og.jpg', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Huninn&family=Noto+Sans+TC:wght@400;500;700&display=swap"
    />
  </head>
  <body>
    <div id="progress"></div>

    <header class="site-header">
      <nav class="nav">
        <a class="brand" href={base} aria-label="Matters 平台小教室 首頁">
          <svg class="brand-logo" viewBox="0 0 97 20" fill="none" role="img" aria-hidden="true"><path fill="currentColor" fill-rule="evenodd" d="M0 19.143V0h4.617l5.184 14.58h.081L15.066 0h4.644v19.143h-3.321V5.616h-.108c-.162.594-.324 1.242-.621 2.052l-4.239 11.475H8.316L4.077 7.668a16.453 16.453 0 01-.621-2.052h-.108v13.527H0zm29.497.405c-4.239 0-7.371-3.51-7.371-7.884 0-4.374 3.132-7.884 7.371-7.884 2.646 0 4.698 1.431 5.643 3.402h.108v-2.97h3.294v14.931h-3.294v-2.916h-.108c-1.296 2.349-3.24 3.321-5.643 3.321zM48.248 4.212h2.686V0h3.375v4.212h2.376v3.159h-2.376v8.613h2.295v3.159h-5.67V7.371h-5.062v8.613h2.295v3.159h-5.67V7.371h-2.295V4.212h2.295V0h3.375v4.212h2.376zm-18.049 12.15c-2.673 0-4.509-2.025-4.509-4.698 0-2.7 1.836-4.698 4.509-4.698 2.7 0 4.563 1.998 4.563 4.698 0 2.673-1.863 4.698-4.563 4.698zm35.679 3.186c-4.563 0-8.127-3.564-8.127-7.938s3.564-7.803 8.127-7.803c4.563 0 8.127 3.429 8.127 7.911 0 .243-.027.675-.108 1.08H61.369c.378 2.052 2.295 3.591 4.563 3.591 1.782 0 3.267-.837 3.969-2.349h3.726c-1.053 3.213-4.023 5.508-7.749 5.508zm-4.455-9.315h8.829c-.297-1.782-2.052-3.267-4.428-3.267s-4.158 1.377-4.401 3.267zm14.539 8.91V4.212h8.991v3.159h-5.589v11.772h-3.402zm14.998.405c-3.186 0-5.562-2.16-5.562-4.779h3.375c.027.972.999 1.674 2.241 1.674 1.323 0 2.16-.648 2.16-1.62 0-1.242-1.323-1.512-2.673-1.863-2.808-.702-4.806-1.863-4.806-4.59 0-2.565 2.322-4.563 5.373-4.563 2.943 0 5.373 2.025 5.373 4.671l-3.375-.027c0-.999-.945-1.566-1.998-1.566-1.08 0-1.998.54-1.998 1.458 0 1.107 1.296 1.377 2.646 1.728 1.998.513 4.752 1.188 4.752 4.698 0 2.646-2.484 4.779-5.508 4.779z"/></svg>
          <span class="brand-sub">平台小教室</span>
        </a>
        <div class="nav-main">
          <ul class="nav-links" set:html={navLinksHtml}></ul>
          <a class="btn btn--ghost btn--sm nav-toc" href="start">全部主題</a>
          <AudienceToggle />
          <a class="nav-en" href="en/">EN</a>
        </div>
      </nav>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          <strong>審查還是抗審查？網路平台「透明開盒」的兩難</strong><br />
          TWNIC 社群計畫結案網站 · 以 Matters.town 為案例的平台治理科普
        </p>
        <p class="note">
          程式碼 MIT／文件 CC BY 4.0／研究資料依敏感度授權 ·
          本站規劃部署於 IPFS：網域被封，內容指紋仍在。
        </p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var bar = document.getElementById('progress');
        function onScroll() {
          var h = document.documentElement;
          var max = h.scrollHeight - h.clientHeight;
          var p = max > 0 ? (h.scrollTop / max) * 100 : 0;
          bar.style.width = p + '%';
        }
        document.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>
    <script is:inline>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var play = function () {
          Array.prototype.forEach.call(document.querySelectorAll('video[data-autoplay]'), function (v) {
            var p = v.play(); if (p && p.catch) p.catch(function () {});
          });
        };
        if (document.readyState !== 'loading') play(); else document.addEventListener('DOMContentLoaded', play);
      })();
    </script>
  </body>
</html>
