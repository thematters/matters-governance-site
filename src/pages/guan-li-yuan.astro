---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cite from '../components/Cite.astro';
import InteractionSlot from '../components/InteractionSlot.astro';

const dispositions = [
  { name: '註銷', desc: '帳號刪除，不可逆。最嚴厲，早期僅用於色情／賭博／迷姦藥等紅線廣告。', sev: '最重' },
  { name: '凍結', desc: '帳號暫時停權。', sev: '重' },
  { name: '禁言', desc: '一段時間內不能發言。', sev: '中' },
  { name: '折疊', desc: '留言被收合，要點開才看得到。', sev: '輕' },
  { name: '小黑屋', desc: '把整個帳號從文章列表踢掉（仍可發文，但不進公共頁面）。', sev: '中' },
  { name: '降噪', desc: '降低內容在排序中的權重。', sev: '輕' },
  { name: '打掃', desc: '由守望相助隊／海巡移除明確的垃圾留言。', sev: '視情況' },
];
---
<BaseLayout title="管理員手段">
  <p class="kicker">管理員手段類別 · 舊版頁面內容</p>
  <h1>七種處置：從「打掃」到「註銷」</h1>
  <p class="lead">
    治理不是只有「刪或不刪」。Matters 後台累積出一整條<strong>嚴厲度 × 可逆性</strong>的光譜，
    大原則是<Cite src="thematters/spam-detection-scaffold" url="https://github.com/thematters/spam-detection-scaffold" quote="不刪除，只是不再被看見">處置上限是降低可見度，而非刪除</Cite>，且盡量可回復、可申訴。
  </p>

  <section class="block">
    <table style="width:100%;border-collapse:collapse;font-size:15px;">
      <thead>
        <tr style="text-align:left;border-bottom:2px solid var(--line);">
          <th style="padding:8px;">手段</th><th style="padding:8px;">說明</th><th style="padding:8px;">嚴厲度</th>
        </tr>
      </thead>
      <tbody>
        {dispositions.map((d) => (
          <tr style="border-bottom:1px solid var(--line);">
            <td style="padding:8px;font-weight:700;">{d.name}</td>
            <td style="padding:8px;color:var(--ink-soft);">{d.desc}</td>
            <td style="padding:8px;"><span class="wip">{d.sev}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="block">
    <h2>為什麼有了小黑屋，就很少註銷了</h2>
    <p>
      一個有意思的設計史：早期之所以對廣告帳號下重手到「註銷」，其實是為了
      <Cite src="Matters 治理史時間線" quote="當時最新 feed 沒有小黑屋功能，洗版會干擾正常用戶體驗；後來有了小黑屋，就很少註銷了，都是踢小黑屋就完">阻止洗版造成的視覺干擾</Cite>。
      2023 年 4 月小黑屋（後臺版）上線後，洗版多半踢進小黑屋即可，處置反而變得更輕、更可逆。工具的進化，讓治理可以更溫和。
    </p>
    <InteractionSlot title="處置光譜尺：拖一拖，比較嚴厲度與可逆性" reference="自訂互動" />
  </section>
</BaseLayout>
