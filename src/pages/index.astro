---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterRail from '../components/ChapterRail.astro';
import StickyScroller from '../components/StickyScroller.astro';
import FalsePositiveSlider from '../components/FalsePositiveSlider.astro';
import RingDetector from '../components/RingDetector.astro';
import RankingSplitScreen from '../components/RankingSplitScreen.astro';
import DecisionBoundary from '../components/DecisionBoundary.astro';
import '../styles/story.css';
---
<BaseLayout title="主敘事">
  <ChapterRail />

  <!-- ───────── 電影感固定背景：常駐影片 + 暗幕（隨捲動變暗→淡出） ─────────
       放在頁面最上層（不在 .banner--hero 內），因為 .full-bleed 帶 transform，
       會讓 position:fixed 失效。這兩層 fixed 在所有內容之後、body 暖米底之上；
       GSAP 驅動 .hero-dark 變暗，捲過 StickyScroller 後整組（影片+暗幕）一起淡出。 -->
  <div class="hero-bg" id="hero-bg" aria-hidden="true">
    <video class="hero-bg__video" muted loop playsinline preload="auto" poster="illustrations/hero.jpg" data-autoplay>
      <source src="illustrations/anim/hero-everyone-moves-loop.webm" type="video/webm" />
      <source src="illustrations/anim/hero-everyone-moves-loop.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="hero-dark" id="hero-dark" aria-hidden="true"></div>

  <!-- ───────── 電影感固定背景②：重見光明（resolution 暖金光吞噬層） ─────────
       與 hero 那套（#hero-bg/#hero-dark）「完全獨立」的另一片固定層：放 light-emergence
       影片，預設 opacity:0 隱形，捲到結論區 .scene--light 時由它「自己的」GSAP ScrollTrigger
       湧現（0→1），完成「下潛暗(spam)→重見光明」的弧線。
       同樣放在頁面頂層、.full-bleed（帶 transform）之外，fixed 才不會失效。
       z-index:1（與 hero-dark 同層但 DOM 在其後）；hero 那組捲過 StickyScroller 後已 opacity:0，
       結論區只剩本層在作用，兩套固定層不會同時搶畫面。 -->
  <div class="spine-light" id="spine-light" aria-hidden="true">
    <video class="spine-light__video" muted loop playsinline preload="none" data-autoplay>
      <source src="illustrations/anim/light-emergence-high-motion-4s.webm" type="video/webm" />
      <source src="illustrations/anim/light-emergence-high-motion-4s.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- 序幕 — HERO（滿版電影感 banner；影片改由上方固定背景提供） -->
  <section class="full-bleed banner banner--hero banner--hero-fixed" id="ch-prologue">
    <div class="banner__inner">
      <p class="kicker">技術文件 · 經典案例 · 開放原始碼大公開</p>
      <h1>看不見的平台清道夫</h1>
      <p class="sub">社群平台的垃圾打掃方法大揭秘</p>
      <p class="scroll-cue">往下捲，親手走一遍</p>
      <img class="scroll-arrow" src="illustrations/objects/down-arrow.png" alt="" aria-hidden="true" />
    </div>
  </section>

  <!-- ───────── 第一章·魔高一尺 ───────── -->
  <div class="chapter-rest chapter-rest--on-media" id="ch-1">
    <p class="chapter-rest__num">第一章</p>
    <h2 class="chapter-rest__name">魔高一尺</h2>
    <p class="chapter-rest__desc">為什麼要審查、為什麼非機器不可</p>
  </div>

  <!-- 核心 sticky scrollytelling：綠紅 feed 隨捲動變狀態 -->
  <StickyScroller />

  <!-- 內嵌互動 · 集團偵測 Ring（第一章動手 beat：偵測抓的是行為樣態）-->
  <section class="scene scene-wide reveal">
    <p class="kicker">親手試 · 集團偵測</p>
    <h2>有些垃圾單篇分數很低，卻是一整群</h2>
    <p>先按「單篇模型偵測」，只有兩個明顯垃圾被抓；再按「集團偵測 Ring」，八個分數低到像正常內容的「翻譯社」帳號，因為同模板、多帳號、短時間，整群一次現形。偵測抓的是行為樣態，不是字句。</p>
    <div class="figure">
      <div class="figure__head"><span class="figure__title">集團掃描：單一模型 vs 行為偵測</span><span class="figure__hint">按按鈕切換</span></div>
      <RingDetector />
    </div>
    <p style="text-align:center"><a class="read-more" href="detection#ring">深入：集團掃描 Ring 與繁簡折疊</a></p>
  </section>

  <!-- ───────── 第二章·道高一尺 ───────── -->
  <div class="chapter-rest" id="ch-2">
    <p class="chapter-rest__num">第二章</p>
    <h2 class="chapter-rest__name">道高一尺</h2>
    <p class="chapter-rest__desc">不同的打掃方法，加上守望相助</p>
  </div>

  <!-- 模型之外的工具箱 -->
  <section class="scene reveal">
    <p class="kicker">模型之外</p>
    <h2>光靠模型不夠</h2>
    <div class="toolkit">
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/broom-quiet-room.png" alt="" /></span>
        <h3>打掃・小黑屋</h3><p>不刪除，只是把帳號/文章移出公共視野——可逆。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/label-hand-card.png" alt="" /></span>
        <h3>人工標記</h3><p>被誤殺的內容被人撿回、重新標記，回灌模型。人在迴圈裡。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/polished-model-gear.png" alt="" /></span>
        <h3>重新訓練</h3><p>模型會「自我中毒」誤判，用大模型重新校正，偽陽性降十倍。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/paper-lantern.png" alt="" /></span>
        <h3>群眾守望</h3><p>守望相助隊一起把垃圾收走，公開可稽核。</p>
      </div>
    </div>
    <a class="read-more" href="moderation">深入：七種處置與小黑屋</a>　<a class="read-more" href="crowd">深入：群眾協力</a>
  </section>

  <!-- 內嵌互動 · 首頁排序對照（第二章動手 beat：決定誰被看見也是治理）-->
  <section class="scene scene-wide reveal">
    <p class="kicker">親手試 · 首頁排序</p>
    <h2>同一批內容，誰會被排到第一名？</h2>
    <p>方法不只「擋垃圾」，也包含「怎麼決定誰被看見」。先猜哪一則會被演算法排到首頁第一，再看時間序與演算法序的對照——分數裡留言權重最高，獎勵的是引發討論，不是純曝光。</p>
    <div class="figure">
      <div class="figure__head"><span class="figure__title">時間序 vs 演算法序</span><span class="figure__hint">點一則先猜</span></div>
      <RankingSplitScreen />
    </div>
    <p style="text-align:center"><a class="read-more" href="ranking">深入：首頁排序與末日爆滑</a></p>
  </section>

  <!-- ───────── 第三章·自己的帳號自己救 ───────── -->
  <div class="chapter-rest" id="ch-3">
    <p class="chapter-rest__num">第三章</p>
    <h2 class="chapter-rest__name">自己的帳號自己救</h2>
    <p class="chapter-rest__desc">方法再好，一定有誤刪受害者——那怎樣會更好？</p>
  </div>

  <!-- 換你親手試 · 偽陽性滑桿（招牌互動） -->
  <section class="scene scene-wide reveal">
    <p class="kicker">換你親手試 · 招牌互動</p>
    <h2>那條門檻，你會設在哪？</h2>
    <p>方法再多，總會誤判。換你站到審查者那一側，親手拖那條線——往嚴拖，垃圾擋更乾淨，但正常內容開始被誤殺（變灰）：尤其是看起來像垃圾的政治評論、學術考據、防詐科普。</p>
    <FalsePositiveSlider />
    <p style="text-align:center">這就是為什麼原則是：<strong>在不確定時，寧可漏看一篇垃圾，不願消音一篇表達。</strong></p>
    <p style="text-align:center"><a class="read-more" href="false-positive">深入：偽陽性與門檻的倫理</a></p>
  </section>

  <!-- 內嵌互動 · 決策邊界（第三章動手 beat：任何一條線都會誤殺）-->
  <section class="scene scene-wide reveal">
    <p class="kicker">親手試 · 決策邊界</p>
    <h2>為什麼一定有人被誤刪？</h2>
    <p>把每篇內容放進二維特徵空間：綠點（正常）聚在左下、紅點（垃圾）聚在右上，中間是兩者重疊的灰色地帶。拖那條分界線——你會看到，<strong>同一條線同時誤殺一些正常、又放過一些垃圾</strong>，這就是偽陽性無法歸零的幾何原因。</p>
    <div class="figure">
      <div class="figure__head"><span class="figure__title">模型怎麼畫那條線：為什麼一定有誤殺</span><span class="figure__hint">拖分界線</span></div>
      <DecisionBoundary />
    </div>
  </section>

  <!-- 更大的問題（抵達光明：暗→光弧線的 resolution，暖金花園光暈）
       多加 scene--light-spine：標記「重見光明」光吞噬層的落地點 + 暖金光上的可讀性處理。 -->
  <section class="scene reveal scene--light scene--light-spine">
    <div class="scene-glow" aria-hidden="true"></div>
    <p class="kicker">更大的問題</p>
    <h2>審查與抗審查，是同一件事的兩面</h2>
    <div class="bigq">
      <a class="board board--hover bigq-card" href="censorship-resistance" style="--bigq-c:#6f8f4e">
        <img class="bigq-thumb" src="illustrations/card-censorship-resistance.jpg" alt="" loading="lazy" />
        <div class="bigq-body">
          <h3>抗審查 <span class="bigq-arr" aria-hidden="true">→</span></h3>
          <p>平台能擋紅色，也可能擋掉它不該擋的。IPFS 讓內容被刪也還在。</p>
        </div>
      </a>
      <a class="board board--hover bigq-card" href="ranking" style="--bigq-c:#c8a020">
        <img class="bigq-thumb" src="illustrations/card-ranking.jpg" alt="" loading="lazy" />
        <div class="bigq-body">
          <h3>排序與末日爆滑 <span class="bigq-arr" aria-hidden="true">→</span></h3>
          <p>就算沒被刪，你看到的順序也被決定了——「決定誰被看見」才是真正的權力。</p>
        </div>
      </a>
      <a class="board board--hover bigq-card" href="history" style="--bigq-c:#c0584a">
        <img class="bigq-thumb" src="illustrations/card-dns-rpz.jpg" alt="" loading="lazy" />
        <div class="bigq-body">
          <h3>當整個網域被封 <span class="bigq-arr" aria-hidden="true">→</span></h3>
          <p>2025 春節，Matters 被 DNS-RPZ 誤封三天。平台第一次成為被治理者。</p>
        </div>
      </a>
    </div>
  </section>

  <!-- ───────── 附錄·源碼與政策模組 ───────── -->
  <section class="scene reveal" id="ch-appendix">
    <p class="kicker">附錄</p>
    <h2>可參考、可使用的源碼模組與政策模組</h2>
    <p>這個站本身就是「透明開盒」：偵測模型、處置流程、垃圾資料集與合規對照都開放可取用——歡迎別的平台拿去打掃。</p>
    <div class="bigq">
      <a class="board board--hover" href="data" style="--bigq-c:#5a8a93">
        <h3>開源與資料集 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>分層揭露、垃圾資料庫公開——可直接接的源碼模組。</p>
      </a>
      <a class="board board--hover" href="ncc" style="--bigq-c:#8a6db0">
        <h3>NCC 合規自評 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>兩份指引 41 項對照——可參考的政策模組。</p>
      </a>
      <a class="board board--hover" href="conclusion" style="--bigq-c:#c8a020">
        <h3>結論與建言 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>三悖論、給平台與主管機關的政策建言。</p>
      </a>
    </div>
    <p style="text-align:center;margin-top:22px">
      <a class="read-more" href="history">治理史編年 2018–2025</a>
      <a class="read-more" href="about">關於・方法・授權</a>
      <a class="read-more" href="start">看全部 14 個主題 →</a>
    </p>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    var nodes = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) {
      [].forEach.call(nodes, function (e) { e.classList.add('in-view'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { en.target.classList.add('in-view'); io.unobserve(en.target); }
      });
    }, { threshold: 0.18 });
    [].forEach.call(nodes, function (e) { io.observe(e); });
  })();
</script>

<script>
  // ───────── 電影感固定背景：隨捲動變暗 → 淡出（GSAP ScrollTrigger） ─────────
  // 完全獨立於 StickyScroller 的 timeline，只操作頁面級的 #hero-bg / #hero-dark。
  // 觸發與範圍：
  //   ① 變暗：以 #scrolly（核心 scrollytelling）為 trigger，從它頂端進場（花園漸暗）
  //      推到中段達到峰值；到後段「收斂」讓位給 scrolly 自己的 .scrolly-atmos，
  //      避免兩層暗幕疊起來變死黑。
  //   ② 淡出：捲過 #scrolly、抵達第二章休息點(#ch-2) 時，整組（影片+暗幕）opacity→0，
  //      下方章節回到 body 暖米底（影片不透在後面）。
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initHeroBg() {
    const heroBg = document.getElementById('hero-bg');
    const heroDark = document.getElementById('hero-dark');
    const scrolly = document.getElementById('scrolly');
    if (!heroBg || !heroDark || heroBg.dataset.inited) return;
    heroBg.dataset.inited = '1';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // reduced-motion：不做捲動變暗動畫；留一層溫和定值暗幕確保標題可讀，影片照常輪播。
    if (reduce) {
      gsap.set(heroDark, { opacity: 0.34 });
      return;
    }

    // 安全保險：沒有 #scrolly 時退化成「只在序幕區段附近顯示、之後淡出」。
    const ch2 = document.getElementById('ch-2');
    const fadeRef = scrolly || ch2 || document.getElementById('ch-1');
    if (!fadeRef) { gsap.set(heroDark, { opacity: 0.34 }); return; }

    // 初始：暗幕清亮（變暗交給捲動），影片背景全顯示。
    gsap.set(heroDark, { opacity: 0 });
    gsap.set(heroBg, { opacity: 1 });

    // 單一時間軸（關鍵：避免兩個 scrub trigger 同時寫 hero-bg/hero-dark 的 opacity 互相打架）。
    //   trigger=#scrolly：top bottom 進場 → bottom top 離場（整段 scrollytelling 捲過視窗）。
    //   前 ~88%：花園隨垃圾湧入而變暗，後段收斂讓位 scrolly 自己的 .scrolly-atmos（不過黑）；
    //   末 ~12%：StickyScroller 捲完時整組（影片+暗幕）淡出 →0。電影區只含 hero+魔高一尺+StickyScroller；
    //   其後的章節與內嵌互動（RingDetector/排序/決策邊界…）都是暖米底實心元件，落在 body 暖米底、不疊在影片上。
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: fadeRef,
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1,
      },
    });
    tl.to(heroDark, { opacity: 0.18, ease: 'none', duration: 0.10 })            // 進場：花園起霧
      .to(heroDark, { opacity: 0.52, ease: 'none', duration: 0.40 })            // 中段：垃圾湧入/審查，最暗
      .to(heroDark, { opacity: 0.30, ease: 'none', duration: 0.38 })            // 後段：收斂讓位 scrolly-atmos
      .to([heroBg, heroDark], { opacity: 0, ease: 'power1.inOut', duration: 0.12 }); // 末段：整組淡出離場

    // 圖片/字體載入造成版面位移 → 刷新 ScrollTrigger 起訖位置（否則 trigger 落點會偏，淡出對不準）。
    window.addEventListener('load', () => ScrollTrigger.refresh());
    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => ScrollTrigger.refresh(), 200);
    });
  }

  // ───────── 重見光明：resolution 暖金光吞噬轉場（獨立 ScrollTrigger） ─────────
  // 與上方 hero 那條 timeline 完全獨立：只操作頁面級的 #spine-light，絕不碰 #hero-bg/#hero-dark。
  // 觸發與範圍：
  //   trigger=.scene--light（結論「更大的問題」），scrub 跟著捲動。
  //   進場（top bottom → top 35%）：光層 opacity 0→1、輕微 scale 1.06→1（光吞噬/重見光明，bloom 感）。
  //   停留：捲過結論主體時維持滿亮，讓 kicker/h2/三張 bigq 卡浮在暖金光上。
  //   離場（bottom 70% → bottom top，進入附錄前）：柔和淡回 opacity 0，確保附錄回到 body 暖米底、內容可讀。
  function initSpineLight() {
    const lightBg = document.getElementById('spine-light');
    const lightScene = document.querySelector('.scene--light');
    if (!lightBg || lightBg.dataset.inited) return;
    lightBg.dataset.inited = '1';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // reduced-motion：不做湧現動畫；給光層一個溫和定值微亮（讓既有 .scene-glow 仍是主角），不報錯。
    if (reduce) {
      gsap.set(lightBg, { opacity: 0.16, scale: 1 });
      return;
    }
    // 沒有結論區（理論上不會）就讓既有 .scene-glow 撐場，光層維持隱形。
    if (!lightScene) { gsap.set(lightBg, { opacity: 0 }); return; }

    // 初始：光層隱形、略放大（湧現起點）。
    gsap.set(lightBg, { opacity: 0, scale: 1.06, transformOrigin: '50% 44%' });

    // 湧現：以結論區進場為觸發，opacity 0→1 + scale 收束（bloom）。
    gsap.timeline({
      scrollTrigger: {
        trigger: lightScene,
        start: 'top bottom',   // 結論區頂端剛進視窗底部 → 光開始湧現
        end: 'top 35%',        // 結論區頂端推到視窗 35% 處 → 光全滿
        scrub: 1,
      },
    }).fromTo(lightBg,
      { opacity: 0, scale: 1.06 },
      { opacity: 1, scale: 1, ease: 'power2.out', duration: 1 });

    // 離場：捲過結論主體、即將進入附錄時柔和淡回，避免暖光殘留在附錄上影響可讀性。
    gsap.to(lightBg, {
      opacity: 0, ease: 'power1.in',
      scrollTrigger: {
        trigger: lightScene,
        start: 'bottom 70%',   // 結論區底端升到視窗 70% 處 → 開始退光
        end: 'bottom top',     // 結論區整段捲過視窗頂 → 光退盡，附錄回暖米底
        scrub: 1,
      },
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroBg);
    document.addEventListener('DOMContentLoaded', initSpineLight);
  } else {
    initHeroBg();
    initSpineLight();
  }
  document.addEventListener('astro:page-load', initHeroBg);
  document.addEventListener('astro:page-load', initSpineLight);
</script>
