---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterRail from '../components/ChapterRail.astro';
import StickyScroller from '../components/StickyScroller.astro';
import FalsePositiveSlider from '../components/FalsePositiveSlider.astro';
import RingDetector from '../components/RingDetector.astro';
import RankingSplitScreen from '../components/RankingSplitScreen.astro';
import DecisionBoundary from '../components/DecisionBoundary.astro';
import ChapterIntro from '../components/ChapterIntro.astro';
import '../styles/story.css';
---
<BaseLayout title="主敘事">
  <!-- ───────── 固定章節背景舞台 ─────────
       各章一張靜態章節圖，隨捲動「交叉淡入」(.is-active + CSS opacity transition＝漸層轉場)，
       上覆一層暗幕(scrim，依章調整暗度以利白字閱讀)。內容(.dark-stage)疊在最上層。
       不再用影片、不再硬切；放頁面頂層、.full-bleed(帶 transform)之外，fixed 才不失效。 -->
  <div class="stage" id="stage" aria-hidden="true">
    <img class="stage__img is-active" data-stage-img="0" src="illustrations/hero.jpg" alt="" />
    <img class="stage__img" data-stage-img="1" src="illustrations/N1-dark-underworld-reference.jpg" alt="" />
    <img class="stage__img" data-stage-img="2" src="illustrations/F2-moderation-spectrum.jpg" alt="" />
    <img class="stage__img" data-stage-img="3" src="illustrations/self-rescue.jpg" alt="" />
    <img class="stage__img" data-stage-img="4" src="illustrations/N2-light-emergence-style-v2.jpg" alt="" />
    <img class="stage__img" data-stage-img="5" src="illustrations/crowd.jpg" alt="" />
  </div>
  <div class="stage-scrim" id="stage-scrim" aria-hidden="true"></div>

  <ChapterRail />

  <div class="dark-stage">
  <!-- 序幕 — HERO（靜態章節圖背景；影片已移除） -->
  <section class="full-bleed banner banner--hero banner--hero-fixed" id="ch-prologue" data-stage="0">
    <div class="banner__inner">
      <p class="kicker">技術文件 · 經典案例 · 開放原始碼大公開</p>
      <h1>看不見的平台清道夫</h1>
      <p class="sub">社群平台的垃圾打掃方法大揭秘</p>
      <p class="scroll-cue">往下捲，親手走一遍</p>
      <img class="scroll-arrow" src="illustrations/objects/down-arrow.png" alt="" aria-hidden="true" />
    </div>
  </section>

  <!-- ───────── 第一章·魔高一尺（背景＝N1 鬼怪暗底，常駐變暗） ───────── -->
  <ChapterIntro id="ch-1" num="第一章" name="魔高一尺" desc="為什麼要審查、為什麼非機器不可" stage={1} />

  <!-- 核心 sticky scrollytelling：綠紅 feed 隨捲動變狀態（疊在第一章 N1 暗底上） -->
  <div data-stage="1"><StickyScroller /></div>

  <!-- ───────── 第二章·道高一尺（背景＝F2 打掃光譜暗底） ───────── -->
  <ChapterIntro id="ch-2" num="第二章" name="道高一尺" desc="不同的打掃方法：門檻、集團、人工、排序" stage={2} />

  <!-- ① 換你親手試 · 偽陽性滑桿（那條門檻你會設在哪）-->
  <section class="scene scene-wide reveal" data-stage="2">
    <p class="kicker">換你親手試 · 招牌互動</p>
    <h2>那條門檻，你會設在哪？</h2>
    <p>方法再多，總會誤判。換你站到審查者那一側，親手拖那條線——往嚴拖，垃圾擋更乾淨，但正常內容開始被誤殺（變灰）：尤其是看起來像垃圾的政治評論、學術考據、防詐科普。</p>
    <FalsePositiveSlider />
    <p style="text-align:center">這就是為什麼原則是：<strong>在不確定時，寧可漏看一篇垃圾，不願消音一篇表達。</strong></p>
    <p style="text-align:center"><a class="read-more" href="false-positive">深入：偽陽性與門檻的倫理</a></p>
  </section>

  <!-- ② 內嵌互動 · 集團偵測 Ring（偵測抓的是行為樣態）-->
  <section class="scene scene-wide reveal" data-stage="2">
    <p class="kicker">親手試 · 集團偵測</p>
    <h2>有些垃圾單篇分數很低，卻是一整群</h2>
    <p>先按「單篇模型偵測」，只有兩個明顯垃圾被抓；再按「集團偵測」，八個分數低到像正常內容的「翻譯社」帳號，因為同模板、多帳號、短時間，整群一次現形。偵測抓的是行為樣態，不是字句。</p>
    <div class="figure">
      <div class="figure__head"><span class="figure__title">集團掃描：單一模型 vs 行為偵測</span><span class="figure__hint">按按鈕切換</span></div>
      <RingDetector />
    </div>
    <p style="text-align:center"><a class="read-more" href="detection#ring">深入：集團掃描與繁簡折疊</a></p>
  </section>

  <!-- ③ 模型之外的工具箱 -->
  <section class="scene scene-wide reveal" data-stage="2">
    <p class="kicker">模型之外</p>
    <h2>光靠模型不夠</h2>
    <div class="toolkit">
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/broom-quiet-room.png" alt="" /></span>
        <h3>打掃・小黑屋</h3><p>不刪除，只是把帳號/文章移出公共視野——可逆。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/label-hand-card.png" alt="" /></span>
        <h3>人工標記</h3><p>被誤殺的內容被人撿回、重新標記，回灌模型。人在迴圈裡。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/polished-model-gear.png" alt="" /></span>
        <h3>重新訓練</h3><p>模型會「自我中毒」誤判，用大模型重新校正，偽陽性降十倍。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/paper-lantern.png" alt="" /></span>
        <h3>群眾守望</h3><p>守望相助隊一起把垃圾收走，公開可稽核。</p>
      </div>
    </div>
    <a class="read-more" href="moderation">深入：七種處置與小黑屋</a>　<a class="read-more" href="crowd">深入：群眾協力</a>
  </section>

  <!-- 內嵌互動 · 首頁排序對照（第二章動手 beat：決定誰被看見也是治理）-->
  <section class="scene scene-wide reveal" data-stage="2">
    <p class="kicker">親手試 · 首頁排序</p>
    <h2>誰能上首頁？是誰設計的？</h2>
    <p>方法不只「擋垃圾」，也包含「怎麼決定誰被看見」。先猜哪一則會被演算法排到首頁第一，再看時間序與演算法序的對照——分數裡留言權重最高，獎勵的是引發討論，不是純曝光。</p>
    <div class="figure">
      <div class="figure__head"><span class="figure__title">時間序 vs 演算法序</span><span class="figure__hint">點一則先猜</span></div>
      <RankingSplitScreen />
    </div>
    <p style="text-align:center"><a class="read-more" href="ranking">深入：首頁排序與末日爆滑</a></p>
  </section>

  <!-- ───────── 第三章·自己的帳號自己救（背景＝self-rescue 暗底） ───────── -->
  <ChapterIntro id="ch-3" num="第三章" name="自己的帳號自己救" desc="誤刪無法歸零——透明的審查、可信的救濟" stage={3} />

  <!-- 內嵌互動 · 決策邊界（為什麼一定有誤殺：誤刪無法歸零的幾何）-->
  <section class="scene scene-wide reveal" data-stage="3">
    <p class="kicker">親手試 · 決策邊界</p>
    <h2>為什麼一定有人被誤刪？</h2>
    <p>把每篇內容放進二維特徵空間：綠點（正常）聚在左下、紅點（垃圾）聚在右上，中間是兩者重疊的灰色地帶。拖那條分界線——你會看到，<strong>同一條線同時誤殺一些正常、又放過一些垃圾</strong>，這就是偽陽性無法歸零的幾何原因。</p>
    <div class="figure">
      <div class="figure__head"><span class="figure__title">模型怎麼畫那條線：為什麼一定有誤殺</span><span class="figure__hint">拖分界線</span></div>
      <DecisionBoundary />
    </div>
  </section>

  <!-- 救濟與透明（第三章主軸：誤刪救得回來、整套審查可被檢驗）-->
  <section class="scene scene-wide reveal" data-stage="3">
    <p class="kicker">那怎樣會更好？</p>
    <h2>誤刪了，怎麼救回來？</h2>
    <p>既然誤刪無法歸零，真正的問題就不只是「少殺一點」，而是<strong>被誤殺的人能不能被救回來</strong>，以及整套審查能不能被外界檢驗。讓平台治理可被信任的，是這三件事：</p>
    <div class="bigq">
      <a class="board board--hover" href="false-positive" style="--bigq-c:#7258FF">
        <h3>申訴與可信救濟 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>程序透明、申訴可近、救濟可用；文章只降能見度不刪除＝可逆，誤判救得回來。</p>
      </a>
      <a class="board board--hover" href="data" style="--bigq-c:#5a8a93">
        <h3>透明開盒 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>把偵測模型、處置流程、資料集都攤開——審查才能被檢驗，也能被別的平台採用。</p>
      </a>
      <a class="board board--hover" href="censorship-resistance" style="--bigq-c:#6f8f4e">
        <h3>自己救內容 · 抗審查 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>就算被下架，IPFS 讓內容指紋還在——使用者始終持有去中心網址。</p>
      </a>
    </div>
  </section>

  <!-- 更大的問題（resolution：背景＝N2 light-emergence 暗底，暖金光透出） -->
  <section class="scene scene-wide reveal" data-stage="4">
    <p class="kicker">更大的問題</p>
    <h2>審查與抗審查，是同一件事的兩面</h2>
    <div class="bigq">
      <a class="board board--hover bigq-card" href="censorship-resistance" style="--bigq-c:#6f8f4e">
        <img class="bigq-thumb" src="illustrations/card-censorship-resistance.jpg" alt="" loading="lazy" />
        <div class="bigq-body">
          <h3>抗審查 <span class="bigq-arr" aria-hidden="true">→</span></h3>
          <p>平台能擋紅色，也可能擋掉它不該擋的。IPFS 讓內容被刪也還在。</p>
        </div>
      </a>
      <a class="board board--hover bigq-card" href="ranking" style="--bigq-c:#c8a020">
        <img class="bigq-thumb" src="illustrations/card-ranking.jpg" alt="" loading="lazy" />
        <div class="bigq-body">
          <h3>排序與末日爆滑 <span class="bigq-arr" aria-hidden="true">→</span></h3>
          <p>就算沒被刪，你看到的順序也被決定了——「決定誰被看見」才是真正的權力。</p>
        </div>
      </a>
      <a class="board board--hover bigq-card" href="history" style="--bigq-c:#c0584a">
        <img class="bigq-thumb" src="illustrations/card-dns-rpz.jpg" alt="" loading="lazy" />
        <div class="bigq-body">
          <h3>當整個網域被封 <span class="bigq-arr" aria-hidden="true">→</span></h3>
          <p>2025 春節，Matters 被 DNS-RPZ 誤封三天。平台第一次成為被治理者。</p>
        </div>
      </a>
    </div>
  </section>

  <!-- ───────── 附錄·源碼與政策模組（背景＝crowd 提燈守望暗底，靜態圖） ───────── -->
  <ChapterIntro id="ch-appendix" num="附錄" name="源碼・政策模組" desc="這個站本身就是「透明開盒」：偵測、處置、資料集都開放可取用" stage={5} />

  <!-- 附錄內容 -->
  <section class="scene reveal" id="appendix-content" data-stage="5">
    <h2>可參考、可使用的源碼模組與政策模組</h2>
    <p>這個站本身就是「透明開盒」：偵測模型、處置流程、垃圾資料集與合規對照都開放可取用——歡迎別的平台拿去打掃。</p>
    <div class="bigq">
      <a class="board board--hover" href="data" style="--bigq-c:#5a8a93">
        <h3>開源與資料集 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>分層揭露、垃圾資料庫公開——可直接接的源碼模組。</p>
      </a>
      <a class="board board--hover" href="ncc" style="--bigq-c:#8a6db0">
        <h3>NCC 合規自評 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>兩份指引 41 項對照——可參考的政策模組。</p>
      </a>
      <a class="board board--hover" href="conclusion" style="--bigq-c:#c8a020">
        <h3>結論與建言 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>三悖論、給平台與主管機關的政策建言。</p>
      </a>
    </div>
    <p style="text-align:center;margin-top:22px">
      <a class="read-more" href="reading/">延伸閱讀：給專業讀者的正式長文 →</a>
      <a class="read-more" href="history">治理史編年 2018–2025</a>
      <a class="read-more" href="about">關於・方法・授權</a>
      <a class="read-more" href="start">看全部 14 個主題 →</a>
    </p>
  </section>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    var nodes = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) {
      [].forEach.call(nodes, function (e) { e.classList.add('in-view'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { en.target.classList.add('in-view'); io.unobserve(en.target); }
      });
    }, { threshold: 0.18 });
    [].forEach.call(nodes, function (e) { io.observe(e); });
  })();
</script>

<script>
  // ───────── 固定章節背景：依捲動位置「交叉淡入」該章靜態圖（漸層轉場）＋調整暗幕 ─────────
  // 內容(.dark-stage)疊在 #stage(各章靜態圖)＋#stage-scrim(暗幕)之上。
  // 每個帶 data-stage 的區段(章節標題段/scene/StickyScroller 包裹)宣告它屬於第幾章；
  // 捲到誰，就把對應 .stage__img 設 is-active（CSS opacity transition 做平滑漸層轉場），
  // 並依該章把暗幕透明度調到「白字可讀」的程度。不用影片、不硬切。
  function initStage() {
    const stage = document.getElementById('stage');
    const scrim = document.getElementById('stage-scrim');
    if (!stage || stage.dataset.inited) return;
    stage.dataset.inited = '1';
    const imgs = Array.prototype.slice.call(stage.querySelectorAll('.stage__img'));
    const markers = Array.prototype.slice.call(document.querySelectorAll('[data-stage]'));
    // 每章暗幕強度（白字可讀；序幕較亮、resolution 留些暖光、附錄稍暗）
    const scrimByStage = [0.40, 0.50, 0.58, 0.58, 0.50, 0.64];

    let current = -1;
    function setStage(idx) {
      if (idx === current) return;
      current = idx;
      imgs.forEach(function (im) { im.classList.toggle('is-active', +im.dataset.stageImg === idx); });
      if (scrim) scrim.style.opacity = String(scrimByStage[idx] != null ? scrimByStage[idx] : 0.55);
    }

    let ticking = false;
    function update() {
      ticking = false;
      const y = window.scrollY + window.innerHeight * 0.42; // 視窗 42% 線：誰的頂端越過它，誰就是當前章
      let active = 0;
      for (let i = 0; i < markers.length; i++) {
        const m = markers[i];
        if (m.getBoundingClientRect().top + window.scrollY <= y) active = +m.getAttribute('data-stage');
      }
      setStage(active);
    }
    function onScroll() { if (!ticking) { window.requestAnimationFrame(update); ticking = true; } }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStage);
  } else {
    initStage();
  }
  document.addEventListener('astro:page-load', initStage);
</script>
