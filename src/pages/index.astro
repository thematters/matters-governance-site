---
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyScroller from '../components/StickyScroller.astro';
import FalsePositiveSlider from '../components/FalsePositiveSlider.astro';
import '../styles/story.css';
---
<BaseLayout title="主敘事">
  <!-- Scene 0 — HERO（滿版電影感 banner） -->
  <section class="full-bleed banner banner--hero">
    <video class="banner-media" muted loop playsinline preload="auto" poster="illustrations/hero.jpg" aria-hidden="true" data-autoplay>
      <source src="illustrations/anim/hero-everyone-moves-loop.webm" type="video/webm" />
      <source src="illustrations/anim/hero-everyone-moves-loop.mp4" type="video/mp4" />
    </video>
    <div class="banner__inner">
      <p class="kicker">透明開盒 · 一般平台不會開源的審查演算法</p>
      <h1>審查，還是抗審查？</h1>
      <p class="sub">往下捲動，親手走一遍：在完全沒有審查的首頁，會發生什麼事。</p>
      <p class="scroll-cue">往下捲</p>
    </div>
  </section>

  <!-- 核心 sticky scrollytelling：綠紅 feed 隨捲動變狀態 -->
  <StickyScroller />

  <!-- 換你親手試 · 偽陽性滑桿（招牌互動） -->
  <section class="scene scene-wide reveal">
    <p class="kicker">換你親手試 · 招牌互動</p>
    <h2>那條門檻，你會設在哪？</h2>
    <p>剛剛是看的，現在換你拖。往嚴拖，垃圾擋更乾淨，但正常內容開始被誤殺（變灰）——尤其是看起來像垃圾的政治評論、學術考據、防詐科普。</p>
    <FalsePositiveSlider />
    <p style="text-align:center">這就是為什麼原則是：<strong>在不確定時，寧可漏看一篇垃圾，不願消音一篇表達。</strong></p>
    <p style="text-align:center"><a class="read-more" href="false-positive">深入：偽陽性與門檻的倫理</a></p>
  </section>

  <!-- 模型之外的工具箱 -->
  <section class="scene reveal">
    <p class="kicker">模型之外</p>
    <h2>光靠模型不夠</h2>
    <div class="toolkit">
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/broom-quiet-room.png" alt="" /></span>
        <h3>打掃・小黑屋</h3><p>不刪除，只是把帳號/文章移出公共視野——可逆。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/label-hand-card.png" alt="" /></span>
        <h3>人工標記</h3><p>被誤殺的內容被人撿回、重新標記，回灌模型。人在迴圈裡。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/polished-model-gear.png" alt="" /></span>
        <h3>重新訓練</h3><p>模型會「自我中毒」誤判，用大模型重新校正，偽陽性降十倍。</p>
      </div>
      <div class="tool board board--hover">
        <span class="tool-ic"><img src="illustrations/objects/paper-lantern.png" alt="" /></span>
        <h3>群眾守望</h3><p>守望相助隊一起把垃圾收走，公開可稽核。</p>
      </div>
    </div>
    <a class="read-more" href="moderation">深入：七種處置與小黑屋</a>　<a class="read-more" href="crowd">深入：群眾協力</a>
  </section>

  <!-- Ring -->
  <section class="scene reveal">
    <p class="kicker">集團偵測 Ring</p>
    <h2>剛剛那群低分卻被一起抓的，是怎麼回事？</h2>
    <p>單篇分數只有 <strong>0.09</strong> 的「翻譯社」幾乎漏網——但它是<strong>一整群幾乎一樣的卡片、來自很多帳號</strong>。集團偵測抓的是這個「行為樣態」，不是字句：同一模板、大量帳號、短時間，一網打盡。可以親手玩玩看。</p>
    <a class="read-more" href="detection#ring">玩玩看：集團掃描 Ring</a>
  </section>

  <!-- 更大的問題（抵達光明：暗→光弧線的 resolution，暖金花園光暈） -->
  <section class="scene reveal scene--light">
    <div class="scene-glow" aria-hidden="true"></div>
    <p class="kicker">更大的問題</p>
    <h2>審查與抗審查，是同一件事的兩面</h2>
    <div class="bigq">
      <a class="board board--hover" href="censorship-resistance" style="--bigq-c:#6f8f4e">
        <h3>抗審查 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>平台能擋紅色，也可能擋掉它不該擋的。IPFS 讓內容被刪也還在。</p>
      </a>
      <a class="board board--hover" href="ranking" style="--bigq-c:#c8a020">
        <h3>排序與末日爆滑 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>就算沒被刪，你看到的順序也被決定了——「決定誰被看見」才是真正的權力。</p>
      </a>
      <a class="board board--hover" href="history" style="--bigq-c:#c0584a">
        <h3>當整個網域被封 <span class="bigq-arr" aria-hidden="true">→</span></h3>
        <p>2025 春節，Matters 被 DNS-RPZ 誤封三天。平台第一次成為被治理者。</p>
      </a>
    </div>
    <p style="text-align:center;margin-top:24px"><a class="read-more" href="start">看全部 14 個主題 →</a></p>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    var nodes = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) {
      [].forEach.call(nodes, function (e) { e.classList.add('in-view'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { en.target.classList.add('in-view'); io.unobserve(en.target); }
      });
    }, { threshold: 0.18 });
    [].forEach.call(nodes, function (e) { io.observe(e); });
  })();
</script>
