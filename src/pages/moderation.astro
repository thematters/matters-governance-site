---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterNav from '../components/ChapterNav.astro';
import ChapterHero from '../components/ChapterHero.astro';
import BeModerator from '../components/BeModerator.astro';
import '../styles/story.css';

// 依「不可逆/嚴厲程度」由輕到重排序，t=0(輕)→1(重) 驅動漸層色
const d = [
  { name: '打掃',   eff: '守望相助隊移除留言並公開存證',                   sev: '視情況', t: 0.10 },
  { name: '降噪',   eff: '依分數在排序 SQL 直接排除',                      sev: '輕',     t: 0.22 },
  { name: '折疊',   eff: '留言收合，仍存在、可展開',                       sev: '輕',     t: 0.34 },
  { name: '小黑屋', eff: '把帳號/文章移出公共列表，但仍 active、直連可開', sev: '中',     t: 0.50 },
  { name: '禁言',   eff: '一段時間不能發言（1–180 天/永久）',              sev: '中',     t: 0.64 },
  { name: '凍結',   eff: '全面停權，連提領、付款都不行',                   sev: '重',     t: 0.82 },
  { name: '註銷',   eff: '帳號刪除，不可逆。最嚴厲，早期僅用於色情/賭博/迷姦藥', sev: '最重', t: 1.00 },
];
---
<BaseLayout title="管理員手段">
  <ChapterHero kicker="主題 · 七種處置" title="從打掃到註銷的光譜" img="illustrations/moderation.jpg" alt="一台推車裝滿被移除的垃圾與黑色小怪物、紅叉卡片" />
  <p class="lead">處置的上限是降低可見度，而非刪除；每一步都在降低「處置的不可逆成本」。</p>

  <div class="spectrum">
    <div class="spectrum-track" aria-hidden="true"></div>
    <div class="spectrum-ends"><span>輕・可逆</span><span>重・不可逆</span></div>
    <div class="spectrum-list">
      {d.map((r) => (
        <div class="spectrum-item board" style={`--sev:hsl(${Math.round(112 - r.t * 104)} 56% 45%)`}>
          <span class="spectrum-bar" aria-hidden="true"></span>
          <span class="spectrum-name">{r.name}</span>
          <span class="spectrum-eff">{r.eff}</span>
          <span class="chip spectrum-chip">{r.sev}</span>
        </div>
      ))}
    </div>
  </div>

  <style>
    .spectrum { margin: 22px 0; }
    .spectrum-track { height: 8px; border-radius: 99px;
      background: linear-gradient(90deg, hsl(112 56% 45%), hsl(48 72% 50%), hsl(8 66% 50%)); }
    .spectrum-ends { display: flex; justify-content: space-between; font: 700 12px var(--font-ui);
      color: var(--ink-soft); margin: 8px 2px 16px; }
    .spectrum-list { display: flex; flex-direction: column; gap: 10px; }
    .spectrum-item { display: grid; grid-template-columns: 4px 84px 1fr auto; align-items: center;
      gap: 14px; padding: 12px 16px; }
    .spectrum-bar { width: 4px; align-self: stretch; border-radius: 99px; background: var(--sev); }
    .spectrum-name { font: 800 16px var(--font-ui); color: var(--ink); }
    .spectrum-eff { font-size: 14px; color: var(--ink-soft); line-height: 1.6; }
    .spectrum-chip { background: color-mix(in srgb, var(--sev) 18%, transparent); color: var(--sev); white-space: nowrap; }
    @media (max-width: 640px) {
      .spectrum-item { grid-template-columns: 4px 1fr; gap: 4px 12px; }
      .spectrum-eff, .spectrum-chip { grid-column: 2; }
      .spectrum-chip { justify-self: start; margin-top: 2px; }
    }
  </style>

  <h2>小黑屋：歪打正著的關鍵發明</h2>
  <p>
    小黑屋（2023.04）的起源出乎設計者意料——它是兩條需求合流：一是運營要逐頻道手動把文章拉出 feed「太累、需要一鍵」；
    二是面對網軍洗版「與其隱藏單篇，不如直接屏蔽帳號，而且新帳號還能衝註冊數」。有了它，洗版多半「踢進去就好」，
    處置反而變得更輕、更可逆。
  </p>

  <h2>未解的張力：帳號主義 vs 作品主義</h2>
  <p>
    運營問「這個帳號違規嗎」，產品問「這篇好嗎、人會不會變」。系統長期<strong>從未定義「誰是 spammer」</strong>，
    用時間切片每期重評、不永久標記——但「人會變好」卻沒有對應的放回機制。這是真實組織在治理複雜度下的痕跡，至今未解。
  </p>
  <div class="figure">
    <div class="figure__head"><span class="figure__title">換你當版主：六個真實案例</span><span class="figure__hint">選 擋／放</span></div>
    <BeModerator />
  </div>

  <ChapterNav slug="moderation" />
</BaseLayout>
